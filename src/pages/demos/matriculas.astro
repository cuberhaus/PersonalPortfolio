---
import DemoLayout from '../../layouts/DemoLayout.astro';
import SPMatriculasDemo from '../../components/demos/SPMatriculasDemo';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const titles = {
  en: "License Plate Detection",
  es: "Detección de Matrículas",
  ca: "Detecció de Matrícules"
};

const leads = {
  en: "Detect and read <strong>license plates</strong> from car images using computer vision. Select a sample image or upload your own, then watch the 3-stage pipeline (<strong>plate detection</strong>, <strong>character segmentation</strong>, <strong>OCR</strong>) process it in real time \u2014 entirely in your browser.",
  es: "Detecta y lee <strong>matrículas</strong> de imágenes de coches usando visión por computador. Selecciona una imagen de muestra o sube la tuya, luego observa cómo el pipeline de 3 etapas (<strong>detección de matrícula</strong>, <strong>segmentación de caracteres</strong>, <strong>OCR</strong>) la procesa en tiempo real \u2014 completamente en tu navegador.",
  ca: "Detecta i llegeix <strong>matrícules</strong> d'imatges de cotxes usant visió per computador. Selecciona una imatge de mostra o puja la teva, després observa com el pipeline de 3 etapes (<strong>detecció de matrícula</strong>, <strong>segmentació de caràcters</strong>, <strong>OCR</strong>) la processa en temps real \u2014 completament al teu navegador."
};

const badges = {
  en: "Computer Vision \u00b7 FIB-UPC",
  es: "Visión por Computador \u00b7 FIB-UPC",
  ca: "Visió per Computador \u00b7 FIB-UPC"
};

const aboutTitles = {
  en: "About this project",
  es: "Sobre este proyecto",
  ca: "Sobre aquest projecte"
};

const aboutDescs = {
  en: "Originally a MATLAB project for the Computer Vision course at FIB-UPC. This browser demo is a port of the original pipeline to JavaScript \u2014 it uses adaptive binarization, morphological filtering, connected component analysis, and template matching to detect license plates and read their characters, all running client-side with no external dependencies.",
  es: "Originalmente un proyecto de MATLAB para el curso de Visión por Computador en la FIB-UPC. Esta demo de navegador es un port del pipeline original a JavaScript \u2014 utiliza binarización adaptativa, filtrado morfológico, análisis de componentes conectadas y coincidencia de plantillas para detectar matrículas y leer sus caracteres, ejecutándose completamente en el cliente sin dependencias externas.",
  ca: "Originalment un projecte de MATLAB per al curs de Visió per Computador a la FIB-UPC. Aquesta demo de navegador és un port del pipeline original a JavaScript \u2014 utilitza binarització adaptativa, filtrat morfològic, anàlisi de components connectades i coincidència de plantilles per detectar matrícules i llegir els seus caràcters, executant-se completament al client sense dependències externes."
};

const viewSource = {
  en: "View source on GitHub",
  es: "Ver código en GitHub",
  ca: "Veure codi a GitHub"
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout title={title} description="License plate detector ported from MATLAB to JavaScript.">
  <div class="container">
    <div class="demo-header">
      <div class="badge">{badge}</div>
      <h1>{title}</h1>
      <p class="demo-lead" set:html={lead} />
      <div class="demo-header-actions">
        {(() => {
          const vs = { en: "View Source on GitHub", es: "Ver código en GitHub", ca: "Veure codi a GitHub" };
          return (
            <a href="https://github.com/cuberhaus/SPMatriculas" class="demo-header-github" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              {vs[lang] || vs.en}
            </a>
          );
        })()}
      </div>
    </div>

    <SPMatriculasDemo lang={lang} client:load />

    <div class="demo-info">
      <h3>{aboutTitles[lang] || aboutTitles.en}</h3>
      <p>{aboutDescs[lang] || aboutDescs.en}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(14,165,233,0.15), rgba(99,102,241,0.1));
    border: 1px solid rgba(14,165,233,0.25);
    color: #0ea5e9;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #0ea5e9, #6366f1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }
  .demo-lead strong { color: var(--text-primary, #e4e4e7); }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 {
    margin-bottom: 0.75rem;
  }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
