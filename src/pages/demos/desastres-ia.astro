---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DesastresIADemo from '../../components/demos/DesastresIADemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('desastres-ia', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="desastres-ia"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/desastresIA"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#22c55e"
    />

    <LiveAppEmbed
      slug="desastres-ia"
      title="DesastresIA Solver"
      dockerCmd="cd desastresIA && docker compose up -d"
      devCmd="cd desastresIA && make dev"
      lang={lang}
      client:load
    />

    <DesastresIADemo lang={lang} client:visible />
  </div>
</DemoLayout>
