---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DesastresIADemo from '../../components/demos/DesastresIADemo';
---

<DemoLayout
  title="Desastres IA — disaster relief local search"
  description="Helicopter assignment for rescue operations: hill climbing and simulated annealing with AIMA (Java)."
>
  <div class="container">
    <div class="demo-header">
      <h1>Desastres IA</h1>
      <p class="demo-lead">
        Local search on a disaster-relief model: helicopters pick up <strong>groups</strong> at
        <strong>centers</strong> in some order. The full solver is <strong>Java + AIMA</strong> (hill climbing,
        simulated annealing). Use the <strong>Run the demo</strong> panel at the bottom of the page for HC/SA in the
        browser (<a href="#desastres-run-demo">jump to demo</a>); the Java JAR scales to full instances and batch experiments.
      </p>
    </div>

    <DesastresIADemo client:load />

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        Coursework for <strong>Artificial Intelligence</strong> (FIB-UPC). Implements multiple successor functions
        and heuristics, compares initial-state strategies, and uses Python to visualize results from batch runs.
      </p>
      <a
        href="https://github.com/cuberhaus/desastresIA"
        target="_blank"
        rel="noopener noreferrer"
        class="demo-link"
      >
        View source on GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }
  .demo-lead {
    color: var(--text-secondary, #a1a1aa);
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.65;
  }
  .demo-lead strong {
    color: var(--text-primary, #e4e4e7);
  }
  .demo-info {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--bg-card, #16161f);
    border: 1px solid var(--border, #27272a);
    border-radius: 0.75rem;
  }
  .demo-info h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }
  .demo-info p {
    color: var(--text-secondary, #a1a1aa);
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent, #6366f1);
    font-weight: 500;
  }
</style>
