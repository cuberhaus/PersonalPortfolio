---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DesastresIADemo from '../../components/demos/DesastresIADemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "Desastres IA",
  es: "Desastres IA",
  ca: "Desastres IA"
};

const leads = {
  en: "Local search on a <strong>disaster-relief</strong> model: helicopters rescue <strong>groups</strong> at <strong>centers</strong> in an optimized order. Full-stack web app with an interactive <strong>2D map solver</strong> and <strong>experiment dashboard</strong> — compare <strong>hill climbing</strong> vs <strong>simulated annealing</strong> with 3 heuristics and 6 successor functions.",
  es: "Búsqueda local en un modelo de <strong>ayuda en desastres</strong>: helicópteros rescatan <strong>grupos</strong> en <strong>centros</strong> en un orden optimizado. App web full-stack con un <strong>mapa 2D interactivo</strong> y un <strong>panel de experimentos</strong> — compara <strong>hill climbing</strong> vs <strong>simulated annealing</strong> con 3 heurísticos y 6 funciones sucesoras.",
  ca: "Cerca local en un model d'<strong>ajuda en desastres</strong>: helicòpters rescaten <strong>grups</strong> en <strong>centres</strong> en un ordre optimitzat. App web full-stack amb un <strong>mapa 2D interactiu</strong> i un <strong>tauler d'experiments</strong> — compara <strong>hill climbing</strong> vs <strong>simulated annealing</strong> amb 3 heurístics i 6 funcions successores."
};

const badges = {
  en: "Artificial Intelligence · Solid.js + FastAPI · FIB-UPC",
  es: "Inteligencia Artificial · Solid.js + FastAPI · FIB-UPC",
  ca: "Intel·ligència Artificial · Solid.js + FastAPI · FIB-UPC"
};

const metaDescs = {
  en: "Helicopter assignment for disaster rescue using hill climbing and simulated annealing. Interactive 2D map solver and experiment dashboard built with Solid.js and FastAPI.",
  es: "Asignación de helicópteros para rescate en desastres usando hill climbing y simulated annealing. Solucionador interactivo con mapa 2D y panel de experimentos con Solid.js y FastAPI.",
  ca: "Assignació d'helicòpters per a rescat en desastres usant hill climbing i simulated annealing. Solucionador interactiu amb mapa 2D i tauler d'experiments amb Solid.js i FastAPI."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout
  title={title}
  description={metaDescs[lang] || metaDescs.en}
  slug="desastres-ia"
>
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/desastresIA"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#22c55e"
    />

    <LiveAppEmbed
      url="http://localhost:8083"
      title="DesastresIA Solver"
      dockerCmd="cd desastresIA && docker compose up -d"
      devCmd="cd desastresIA && make dev"
      lang={lang}
      fallbackSelector="#desastres-mock-fallback"
      client:load
    />

    <div id="desastres-mock-fallback">
      <DesastresIADemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>
