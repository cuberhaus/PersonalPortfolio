---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DesastresIADemo from '../../components/demos/DesastresIADemo';
---

<DemoLayout
  title="Desastres IA — disaster relief local search"
  description="Helicopter assignment for disaster rescue operations using hill climbing and simulated annealing with AIMA (Java)."
>
  <div class="container">
    <div class="demo-header">
      <div class="badge">Artificial Intelligence · FIB-UPC</div>
      <h1>Desastres IA</h1>
      <p class="demo-lead">
        Local search on a <strong>disaster-relief</strong> model: helicopters rescue
        <strong>groups</strong> at <strong>centers</strong> in an optimized order. Compare
        <strong>hill climbing</strong> vs <strong>simulated annealing</strong> — runs entirely
        in your browser.
      </p>
    </div>

    <DesastresIADemo client:load />
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(34,197,94,0.1));
    border: 1px solid rgba(99,102,241,0.25);
    color: #6366f1;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #6366f1, #22c55e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: #a1a1aa;
    font-size: 1rem;
    line-height: 1.7;
    max-width: 40rem;
    margin: 0 auto;
  }
  .demo-lead strong { color: #e4e4e7; }
</style>
