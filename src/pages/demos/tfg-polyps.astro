---
import DemoLayout from '../../layouts/DemoLayout.astro';
import TfgPolypDemo from '../../components/demos/TfgPolypDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "Polyp Detection with Generative Data Augmentation",
  es: "Detección de Pólipos con Aumento de Datos Generativo",
  ca: "Detecció de Pòlips amb Augment de Dades Generatiu"
};

const leads = {
  en: "Train <strong>Faster R-CNN</strong>, <strong>RetinaNet</strong>, and <strong>SSD</strong> detectors on colonoscopy data, augmented with synthetic images from <strong>CycleGAN</strong> and <strong>SPADE</strong> generative models. Hyperparameter search via <strong>Optuna</strong> &amp; <strong>Ray Tune</strong>.",
  es: "Entrena detectores <strong>Faster R-CNN</strong>, <strong>RetinaNet</strong> y <strong>SSD</strong> en datos de colonoscopia, aumentados con imágenes sintéticas de modelos generativos <strong>CycleGAN</strong> y <strong>SPADE</strong>. Búsqueda de hiperparámetros vía <strong>Optuna</strong> y <strong>Ray Tune</strong>.",
  ca: "Entrena detectors <strong>Faster R-CNN</strong>, <strong>RetinaNet</strong> i <strong>SSD</strong> en dades de colonoscòpia, augmentades amb imatges sintètiques de models generatius <strong>CycleGAN</strong> i <strong>SPADE</strong>. Cerca d'hiperparàmetres via <strong>Optuna</strong> i <strong>Ray Tune</strong>."
};

const badges = {
  en: "Deep Learning · Bachelor's Thesis · FIB-UPC",
  es: "Deep Learning · Trabajo de Fin de Grado · FIB-UPC",
  ca: "Deep Learning · Treball de Fi de Grau · FIB-UPC"
};

const metaTitles = {
  en: "Bachelor's Thesis — Polyp Detection",
  es: "Trabajo de Fin de Grado — Detección de Pólipos",
  ca: "Treball de Fi de Grau — Detecció de Pòlips"
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
const metaTitle = metaTitles[lang] || metaTitles.en;
---

<DemoLayout
  title={metaTitle}
  description="Bachelor's thesis: deep learning polyp detection in colonoscopy videos with CycleGAN/SPADE data augmentation and Faster R-CNN object detection."
  slug="tfg-polyps"
>
  <div class="container">
    <div class="demo-header">
      <div class="badge">{badge}</div>
      <h1>{title}</h1>
      <p class="demo-lead" set:html={lead} />
      <div class="demo-header-actions">
        {(() => {
          const vs = { en: "View Source on GitHub", es: "Ver código en GitHub", ca: "Veure codi a GitHub" };
          return (
            <a href="https://github.com/cuberhaus/TFG" class="demo-header-github" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              {vs[lang] || vs.en}
            </a>
          );
        })()}
      </div>
    </div>

    <TfgPolypDemo lang={lang} client:load />
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(14,165,233,0.1));
    border: 1px solid rgba(16,185,129,0.25);
    color: #10b981;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #10b981, #0ea5e9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 42rem;
    margin: 0 auto;
  }
  .demo-lead strong { color: var(--text-primary); }
  .demo-lead a { color: #0ea5e9; text-decoration: none; }
  .demo-lead a:hover { text-decoration: underline; }
</style>
