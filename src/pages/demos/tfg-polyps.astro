---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import TfgPolypDemo from '../../components/demos/TfgPolypDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('tfg-polyps', lang);
---

<DemoLayout
  title={demo.metaTitle ?? demo.title}
  description={demo.metaDescription}
  slug="tfg-polyps"
  ogImage="/og/tfg-polyps-og.png"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={demo.github}
      githubLabel={t('demo.viewSource')}
      accent={demo.accent}
    />

    <TfgPolypDemo lang={lang} client:visible />
  </div>
</DemoLayout>

<style>
  :global(.demo-hdr-lead a) {
    color: var(--accent-text);
    text-decoration: none;
  }
  :global(.demo-hdr-lead a:hover) {
    text-decoration: underline;
  }
</style>
