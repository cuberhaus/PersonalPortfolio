---
import DemoLayout from '../../layouts/DemoLayout.astro';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isDev = import.meta.env.DEV;

const TRANSLATIONS = {
  en: {
    title: "Recommendation System",
    desc: "A Java Spring Boot content-based recommendation system.",
    badge: "Java \u00b7 Spring Boot \u00b7 FIB-UPC",
    lead: "A content-based recommendation system built with <strong>Java</strong>, <strong>Spring Boot</strong>, and <strong>Thymeleaf</strong>. It models users, items, and ratings to provide personalized recommendations.",
    liveApp: "Live app (runs locally)",
    startHint: "Start the Spring Boot app: <code>cd subgrup-prop7.1 && make web</code>",
    openNewTab: "Open in new tab",
    demoUnavail: "Demo unavailable",
    unavailDesc: "This Java Spring Boot application only runs locally during development. <br/>Check out the source code below to run it yourself!",
    aboutTitle: "About this project",
    aboutDesc: "A university project for the \"Projectes de Programaci\u00f3\" course at FIB-UPC. The core domain logic is written in pure Java and features complex data structures and algorithms for filtering and recommending items based on past user ratings and item attributes (K-Nearest Neighbors and Collaborative Filtering concepts). The web interface is powered by Spring Boot and server-side rendered with Thymeleaf and Bootstrap 5.",
    runLocal: "Run the real app locally",
    step1: "<code>cd subgrup-prop7.1</code>",
    step2: "<code>make web</code> \u2014 compiles and starts the Spring Boot server",
    step3: "The app will run at <a href=\"http://localhost:8081\" target=\"_blank\" rel=\"noopener\">localhost:8081</a>",
    viewSource: "View source on GitHub"
  },
  es: {
    title: "Sistema de Recomendaci\u00f3n",
    desc: "Un sistema de recomendaci\u00f3n basado en contenido con Java Spring Boot.",
    badge: "Java \u00b7 Spring Boot \u00b7 FIB-UPC",
    lead: "Un sistema de recomendaci\u00f3n basado en contenido construido con <strong>Java</strong>, <strong>Spring Boot</strong> y <strong>Thymeleaf</strong>. Modela usuarios, \u00edtems y valoraciones para proporcionar recomendaciones personalizadas.",
    liveApp: "App en vivo (se ejecuta localmente)",
    startHint: "Inicia la app Spring Boot: <code>cd subgrup-prop7.1 && make web</code>",
    openNewTab: "Abrir en nueva pesta\u00f1a",
    demoUnavail: "Demo no disponible",
    unavailDesc: "Esta aplicaci\u00f3n Java Spring Boot solo se ejecuta localmente durante el desarrollo. <br/>\u00a1Revisa el c\u00f3digo fuente a continuaci\u00f3n para ejecutarla t\u00fa mismo!",
    aboutTitle: "Sobre este proyecto",
    aboutDesc: "Un proyecto universitario para el curso \"Projectes de Programaci\u00f3\" en la FIB-UPC. La l\u00f3gica central del dominio est\u00e1 escrita en Java puro e incluye complejas estructuras de datos y algoritmos para filtrar y recomendar \u00edtems bas\u00e1ndose en valoraciones pasadas de usuarios y atributos de \u00edtems (conceptos de K-Nearest Neighbors y Filtrado Colaborativo). La interfaz web est\u00e1 impulsada por Spring Boot y renderizada en el servidor con Thymeleaf y Bootstrap 5.",
    runLocal: "Ejecutar la app real localmente",
    step1: "<code>cd subgrup-prop7.1</code>",
    step2: "<code>make web</code> \u2014 compila e inicia el servidor Spring Boot",
    step3: "La app se ejecutar\u00e1 en <a href=\"http://localhost:8081\" target=\"_blank\" rel=\"noopener\">localhost:8081</a>",
    viewSource: "Ver c\u00f3digo en GitHub"
  },
  ca: {
    title: "Sistema de Recomanaci\u00f3",
    desc: "Un sistema de recomanaci\u00f3 basat en contingut amb Java Spring Boot.",
    badge: "Java \u00b7 Spring Boot \u00b7 FIB-UPC",
    lead: "Un sistema de recomanaci\u00f3 basat en contingut constru\u00eft amb <strong>Java</strong>, <strong>Spring Boot</strong> i <strong>Thymeleaf</strong>. Modela usuaris, \u00edtems i valoracions per proporcionar recomanacions personalitzades.",
    liveApp: "App en viu (s'executa localment)",
    startHint: "Inicia l'app Spring Boot: <code>cd subgrup-prop7.1 && make web</code>",
    openNewTab: "Obrir en nova pestanya",
    demoUnavail: "Demo no disponible",
    unavailDesc: "Aquesta aplicaci\u00f3 Java Spring Boot nom\u00e9s s'executa localment durant el desenvolupament. <br/>Revisa el codi font a continuaci\u00f3 per executar-la tu mateix!",
    aboutTitle: "Sobre aquest projecte",
    aboutDesc: "Un projecte universitari per al curs \"Projectes de Programaci\u00f3\" a la FIB-UPC. La l\u00f2gica central del domini est\u00e0 escrita en Java pur i inclou complexes estructures de dades i algorismes per filtrar i recomanar \u00edtems basant-se en valoracions passades d'usuaris i atributs d'\u00edtems (conceptes de K-Nearest Neighbors i Filtratge Col\u00b7laboratiu). La interf\u00edcie web est\u00e0 impulsada per Spring Boot i renderitzada al servidor amb Thymeleaf i Bootstrap 5.",
    runLocal: "Executar l'app real localment",
    step1: "<code>cd subgrup-prop7.1</code>",
    step2: "<code>make web</code> \u2014 compila i inicia el servidor Spring Boot",
    step3: "L'app s'executar\u00e0 a <a href=\"http://localhost:8081\" target=\"_blank\" rel=\"noopener\">localhost:8081</a>",
    viewSource: "Veure codi a GitHub"
  }
};

const t = TRANSLATIONS[lang] || TRANSLATIONS.en;
---

<DemoLayout title={t.title} description={t.desc}>
  <div class="container">
    <div class="demo-header">
      <div class="badge">{t.badge}</div>
      <h1>{t.title}</h1>
      <p class="demo-lead" set:html={t.lead} />
    </div>

    {isDev ? (
      <div class="demo-local-section">
        <div class="demo-local-header">
          <h3>{t.liveApp}</h3>
          <p class="demo-local-hint" set:html={t.startHint}></p>
          <a href="http://localhost:8081" target="_blank" rel="noopener noreferrer" class="demo-open-btn">
            {t.openNewTab}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
          </a>
        </div>
        <iframe
          src="http://localhost:8081"
          title={t.title}
          class="demo-iframe"
        />
      </div>
    ) : (
      <div class="demo-local-section">
        <div class="demo-local-header">
          <h3>{t.demoUnavail}</h3>
        </div>
        <div style="padding: 2rem; text-align: center; color: var(--text-muted);" set:html={t.unavailDesc}></div>
      </div>
    )}

    <div class="demo-info">
      <h3>{t.aboutTitle}</h3>
      <p>{t.aboutDesc}</p>
      {isDev && (
        <div class="run-local-box">
          <h4>{t.runLocal}</h4>
          <ol>
            <li set:html={t.step1}></li>
            <li set:html={t.step2}></li>
            <li set:html={t.step3}></li>
          </ol>
        </div>
      )}
      <a href="https://github.com/cuberhaus/subgrup-prop7.1" target="_blank" rel="noopener noreferrer" class="demo-link">
        {t.viewSource}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(234, 88, 12, 0.15), rgba(249, 115, 22, 0.1));
    border: 1px solid rgba(234, 88, 12, 0.25);
    color: #f97316;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #ea580c, #f97316);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }
  .demo-lead strong { color: var(--text-primary, #e4e4e7); }

  .demo-local-section {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    margin-bottom: 0;
  }

  .demo-local-header {
    padding: 1rem 1.5rem;
    background: rgba(234, 88, 12, 0.08);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .demo-local-header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .demo-local-hint {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
    min-width: 200px;
  }

  .demo-local-hint code {
    font-size: 0.75rem;
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }

  .demo-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-start);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .demo-open-btn:hover {
    color: var(--accent-end);
    background: var(--bg-card-hover);
  }

  .demo-iframe {
    width: 100%;
    height: 600px;
    min-height: 500px;
    border: none;
    display: block;
  }

  .run-local-box {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-start);
  }

  .run-local-box h4 { margin-bottom: 0.5rem; font-size: 0.95rem; }

  .run-local-box ol {
    margin: 0.5rem 0 0 1.25rem;
    padding: 0;
  }

  .run-local-box li {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .run-local-box code {
    background: var(--bg-card);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-start);
    transition: color var(--transition-fast);
  }

  .demo-link:hover { color: var(--accent-end); }
</style>