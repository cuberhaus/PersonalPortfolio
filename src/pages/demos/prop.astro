---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isDev = import.meta.env.DEV;

// Comprovar si el backend local està actiu intentant fer un fetch
let backendActive = false;
if (isDev) {
  try {
    const response = await fetch('http://localhost:8081/', {
      method: 'HEAD',
      // Un timeout curt perquè no pengi la càrrega de la pàgina
      signal: AbortSignal.timeout(500)
    });
    backendActive = response.ok;
  } catch (error) {
    // Si hi ha un error (connexió refusada, timeout, etc.), el backend no està actiu
    backendActive = false;
  }
}

// Mostra la iframe si estem en DEV I el backend està actiu
const showIframe = isDev && backendActive;

const TRANSLATIONS = {
