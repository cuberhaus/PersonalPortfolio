const tr = TRANSLATIONS[lang] || TRANSLATIONS.en;
const t = useTranslations(lang);
---

<DemoLayout title={tr.title} description={tr.desc} slug="prop">
  <div class="container">
    <DemoHeader
      badge={tr.badge}
      title={tr.title}
      lead={tr.lead}
      githubUrl="https://github.com/cuberhaus/subgrup-prop7.1"
      githubLabel={t('demo.viewSource')}
      accentFrom="#ea580c"
      accentTo="#f97316"
    />

    {showIframe ? (
      <div class="demo-local-section">
        <div class="demo-local-header">
          <h3>{tr.liveApp}</h3>
          <p class="demo-local-hint" set:html={tr.startHint}></p>
          <a href="http://localhost:8081" target="_blank" rel="noopener noreferrer" class="demo-open-btn">
            {tr.openNewTab}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
          </a>
        </div>
        <iframe
          src="http://localhost:8081"
          title={tr.title}
          class="demo-iframe"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="demo-local-section">
        <div class="demo-local-header" style="justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <h3>{tr.demoUnavail}</h3>
          </div>
          <span class="badge" style="margin: 0; font-size: 0.65rem;">Interactive Mock</span>
        </div>
        <div class="mock-browser">
          <div class="mock-nav">
            <div class="mock-nav-brand">{tr.mockNavBrand}</div>
            <div class="mock-nav-links">
              <button class="mock-nav-link active" data-mock-tab="home">{tr.mockNavHome}</button>
              <button class="mock-nav-link" data-mock-tab="types">{tr.mockNavTypes}</button>
              <button class="mock-nav-link" data-mock-tab="items">{tr.mockNavItems}</button>
              <button class="mock-nav-link" data-mock-tab="users">{tr.mockNavUsers}</button>
              <button class="mock-nav-link" data-mock-tab="ratings">{tr.mockNavRatings}</button>
              <button class="mock-nav-link" data-mock-tab="recs">{tr.mockNavRecs}</button>
            </div>
          </div>
          <div class="mock-content">
            <div class="mock-tab-content active" id="mock-home">
              <h2 class="mock-page-title">{tr.mockDashTitle}</h2>
              <div class="mock-alert">
                <strong>Hint:</strong> {tr.mockHint}
              </div>
              <div class="mock-dashboard-grid">
                <div class="mock-card">
                  <div class="mock-card-title">{tr.mockDashType}</div>
                  <div class="mock-card-value text-accent">Films</div>
                </div>
                <div class="mock-card">
                  <div class="mock-card-title">{tr.mockDashUsers}</div>
                  <div class="mock-card-value">2</div>
                </div>
                <div class="mock-card">
                  <div class="mock-card-title">{tr.mockDashItems}</div>
                  <div class="mock-card-value">250</div>
                </div>
                <div class="mock-card">
                  <div class="mock-card-title">{tr.mockDashRatings}</div>
                  <div class="mock-card-value">878</div>
                </div>
              </div>
              <div class="mock-card mock-session-card">
                <div class="mock-card-title">{tr.mockDashSession}</div>
                <div class="mock-card-value text-success">{tr.mockSessionActive}</div>
              </div>
            </div>

            <div class="mock-tab-content" id="mock-types">
              <h2 class="mock-page-title">{tr.mockNavTypes}</h2>
              <div class="mock-card">
                <table class="mock-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>Accions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Films</td>
                      <td>
                        <button class="mock-btn mock-btn-outline" onclick="alert('In the live demo, this selects the dataset.')">Selecciona</button>
                      </td>
                    </tr>
                    <tr>
                      <td>Books</td>
                      <td>
                        <button class="mock-btn mock-btn-outline" onclick="alert('In the live demo, this selects the dataset.')">Selecciona</button>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="mock-tab-content" id="mock-items">
              <h2 class="mock-page-title">{tr.mockNavItems}</h2>
              <div class="mock-card">
                <div class="mock-table-responsive">
                  <table class="mock-table">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Director</th>
                        <th>Genre</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>101</td>
                        <td>Inception</td>
                        <td>Nolan</td>
                        <td>Sci-Fi</td>
                      </tr>
                      <tr>
                        <td>102</td>
                        <td>Interstellar</td>
                        <td>Nolan</td>
                        <td>Sci-Fi</td>
                      </tr>
                      <tr>
                        <td>103</td>
                        <td>The Godfather</td>
                        <td>Coppola</td>
                        <td>Crime</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            
            <div class="mock-tab-content" id="mock-users">
              <h2 class="mock-page-title">{tr.mockNavUsers}</h2>
              <div class="mock-card">
                <table class="mock-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>ID</th>
                      <th>Actiu</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>admin</td>
                      <td>1</td>
                      <td>true</td>
                    </tr>
                    <tr>
                      <td>test_user</td>
                      <td>2</td>
                      <td>true</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
            
            <div class="mock-tab-content" id="mock-ratings">
              <h2 class="mock-page-title">{tr.mockNavRatings}</h2>
              <div class="mock-card">
                <table class="mock-table">
                  <thead>
                    <tr>
                      <th>Usuari</th>
                      <th>Ítem</th>
                      <th>Valoració</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>1</td>
                      <td>101</td>
                      <td>5.0</td>
                    </tr>
                    <tr>
                      <td>1</td>
                      <td>102</td>
                      <td>4.5</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="mock-tab-content" id="mock-recs">
              <h2 class="mock-page-title">{tr.mockNavRecs}</h2>
              <div class="mock-recs-grid">
                <div class="mock-card">
                  <h3 style="margin-top: 0; font-size: 1rem; margin-bottom: 1rem; color: #fff;">Mètode de recomanació</h3>
                  <select class="mock-select" style="margin-bottom: 1rem;">
                    <option>Collaborative</option>
                    <option>Content Based</option>
                    <option>Hybrid</option>
                  </select>
                  <button class="mock-btn mock-btn-primary" style="width: 100%;" onclick="alert('In the live demo, this computes recommendations based on your profile.')">Obté recomanació</button>
                </div>
                <div class="mock-card">
                  <div class="mock-table-responsive">
                    <table class="mock-table">
                      <thead>
                        <tr>
                          <th>ID</th>
                          <th>Title</th>
                          <th>Genre</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td>104</td>
                          <td>Pulp Fiction</td>
                          <td>Crime</td>
                        </tr>
                        <tr>
                          <td>105</td>
                          <td>Spirited Away</td>
                          <td>Animation</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <div class="demo-info">
      <h3>{tr.aboutTitle}</h3>
      <p>{tr.aboutDesc}</p>
      {isDev && (
        <div class="run-local-box">
          <h4>{tr.runLocal}</h4>
          <ol>
            <li set:html={tr.step1}></li>
            <li set:html={tr.step2}></li>
            <li set:html={tr.step3}></li>
          </ol>
        </div>
      )}
      
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const initTabs = () => {
          const tabs = document.querySelectorAll('.mock-nav-link');
          const contents = document.querySelectorAll('.mock-tab-content');

          if (tabs.length === 0 || contents.length === 0) return;

          tabs.forEach(tab => {
            // Remove old listeners to prevent duplicates if initTabs runs multiple times
            const newTab = tab.cloneNode(true);
            tab.parentNode.replaceChild(newTab, tab);

            newTab.addEventListener('click', (e) => {
              e.preventDefault();
              
              const allTabs = document.querySelectorAll('.mock-nav-link');
              const allContents = document.querySelectorAll('.mock-tab-content');

              allTabs.forEach(t => t.classList.remove('active'));
              allContents.forEach(c => c.classList.remove('active'));

              newTab.classList.add('active');

              const targetId = `mock-${newTab.getAttribute('data-mock-tab')}`;
              const targetContent = document.getElementById(targetId);
              if (targetContent) {
                targetContent.classList.add('active');
              }
            });
          });
        };

        // Run on initial load
        initTabs();
        
        // Also run on Astro page load events if using ViewTransitions
        document.addEventListener('astro:page-load', initTabs);
      });
    </script>
  </div>
</DemoLayout>

<style>
  .demo-local-section {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    margin-bottom: 0;
  }

  .demo-local-header {
    padding: 1rem 1.5rem;
    background: color-mix(in srgb, var(--accent-start) 8%, transparent);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .demo-local-header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .demo-local-hint {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
    min-width: 200px;
  }

  .demo-local-hint code {
    font-size: 0.75rem;
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }

  .demo-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-start);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .demo-open-btn:hover {
    color: var(--accent-end);
    background: var(--bg-card-hover);
  }

  .demo-iframe {
    width: 100%;
    height: 600px;
    min-height: 500px;
    border: none;
    display: block;
  }

  .run-local-box {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-start);
  }

  .run-local-box h4 { margin-bottom: 0.5rem; font-size: 0.95rem; }

  .run-local-box ol {
    margin: 0.5rem 0 0 1.25rem;
    padding: 0;
  }

  .run-local-box li {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .run-local-box code {
    background: var(--bg-card);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* Mock UI Styles */
  .mock-browser {
    background-color: #212529; /* Bootstrap dark background */
    color: #dee2e6; /* Bootstrap dark text */
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    display: flex;
    flex-direction: column;
    height: 600px;
    min-height: 500px;
    width: 100%;
    border-top: 1px solid var(--border-color);
  }

  .mock-nav {
    background-color: #2b3035; /* Bootstrap bg-dark subtle */
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #495057;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .mock-nav-brand {
    font-size: 1.25rem;
    color: #fff;
    margin-right: 1.5rem;
  }

  .mock-nav-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .mock-nav-link {
    background: transparent;
    border: none;
    color: rgba(255,255,255,.55);
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 0.375rem;
    transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out;
  }

  .mock-nav-link:hover {
    color: rgba(255,255,255,.75);
  }

  .mock-nav-link.active {
    color: #fff;
    font-weight: bold;
  }

  .mock-content {
    padding: 2rem;
    overflow-y: auto;
    flex: 1;
  }

  .mock-tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .mock-tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mock-page-title {
    font-size: 1.75rem;
    color: #fff;
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .mock-alert {
    background-color: rgba(88, 166, 255, 0.1);
    color: #dee2e6;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .mock-dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .mock-recs-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .mock-recs-grid {
      grid-template-columns: 1fr;
    }
  }

  .mock-card {
    background-color: #2b3035;
    border: 1px solid #495057;
    border-radius: 0.375rem;
    padding: 1.5rem;
    display: flex;
