---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import GraficsDemo from '../../components/demos/GraficsDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "Computer Graphics Shader Playground",
  es: "Playground de Shaders de Gráficos",
  ca: "Playground de Shaders de Gràfics"
};

const leads = {
  en: "Interactive <strong>WebGL2</strong> shader playground porting the FIB-UPC <strong>Gràfics</strong> (Computer Graphics) course labs to the browser: vertex transforms (wave, twist, bounce), <strong>Phong/Blinn-Phong</strong> lighting with 4-light setups, procedural textures (marble, fire), fragment patterns (checkerboard, Senyera, CRT, Hinomaru), geometry shader emulation (explode, voxelize), and advanced effects (shadow mapping, reflections, bloom).",
  es: "Playground interactivo de shaders <strong>WebGL2</strong> que porta las prácticas de <strong>Gràfics</strong> (Gráficos por Computador) de FIB-UPC al navegador: transformaciones de vértices (onda, torsión, rebote), iluminación <strong>Phong/Blinn-Phong</strong> con 4 luces, texturas procedurales (mármol, fuego), patrones de fragmento (tablero, Senyera, CRT, Hinomaru), emulación de geometry shaders (explosión, voxelización), y efectos avanzados (shadow mapping, reflejos, bloom).",
  ca: "Playground interactiu de shaders <strong>WebGL2</strong> que porta les pràctiques de <strong>Gràfics</strong> (Gràfics per Computador) de FIB-UPC al navegador: transformacions de vèrtexs (ona, torsió, rebot), il·luminació <strong>Phong/Blinn-Phong</strong> amb 4 llums, textures procedurals (marbre, foc), patrons de fragment (escaquer, Senyera, CRT, Hinomaru), emulació de geometry shaders (explosió, voxelització), i efectes avançats (shadow mapping, reflexions, bloom)."
};

const badges = {
  en: "Computer Graphics · WebGL2 + GLSL · FIB-UPC",
  es: "Gráficos por Computador · WebGL2 + GLSL · FIB-UPC",
  ca: "Gràfics per Computador · WebGL2 + GLSL · FIB-UPC"
};

const metaDescs = {
  en: "Interactive WebGL2 shader playground: vertex transforms, Phong lighting, procedural textures, fragment patterns, geometry effects, and advanced rendering.",
  es: "Playground interactivo de shaders WebGL2: transformaciones de vértices, iluminación Phong, texturas procedurales, patrones y efectos avanzados.",
  ca: "Playground interactiu de shaders WebGL2: transformacions de vèrtexs, il·luminació Phong, textures procedurals, patrons i efectes avançats."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout
  title={title}
  description={metaDescs[lang] || metaDescs.en}
  slug="grafics"
>
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/fib"
      githubLabel={t('demo.viewSource')}
      accentFrom="#58a6ff"
      accentTo="#da77f2"
    />

    <LiveAppEmbed
      url="http://localhost:8093"
      title="Gràfics Shader Playground"
      dockerCmd="cd fib/G/web && docker compose up -d"
      devCmd="cd fib/G/web && make dev"
      lang={lang}
      fallbackSelector="#grafics-mock-fallback"
      client:load
    />

    <div id="grafics-mock-fallback">
      <GraficsDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>
