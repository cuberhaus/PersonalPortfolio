---
import DemoLayout from '../../layouts/DemoLayout.astro';
import TendaDemo from '../../components/demos/TendaDemo';

const isDev = import.meta.env.DEV;
---

<DemoLayout title="Tenda Online" description="A full PHP e-commerce store with product browsing, cart, and checkout.">
  <div class="container">
    <div class="demo-header">
      <div class="badge">Web Development · FIB-UPC</div>
      <h1>Tenda Online</h1>
      <p class="demo-lead">
        A fully functional <strong>e-commerce store</strong> built with <strong>PHP</strong> and <strong>MySQL</strong>. Browse products by category,
        add items to your cart, and go through the checkout flow.
      </p>
    </div>

    {isDev ? (
      <div class="tenda-local-section">
        <div class="tenda-local-header">
          <h3>Live app (runs locally)</h3>
          <p class="tenda-local-hint">
            Start the PHP app: <code>cd tenda_online && docker compose up -d && ./start.sh</code>
          </p>
          <a href="http://localhost:8888" target="_blank" rel="noopener noreferrer" class="tenda-open-btn">
            Open in new tab
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
          </a>
        </div>
        <iframe
          src="http://localhost:8888"
          title="Tenda Online"
          class="tenda-iframe"
        />
      </div>
    ) : (
      <div class="tenda-demo-wrapper">
        <TendaDemo client:load />
      </div>
    )}

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        A complete e-commerce platform with product catalog, category browsing, shopping cart,
        checkout flow, and an admin order management panel. Features include dynamic product pages,
        cart persistence, and order processing.
      </p>
      {isDev && (
        <div class="run-local-box">
          <h4>Run the real app locally</h4>
          <ol>
            <li><code>cd tenda_online</code></li>
            <li><code>docker compose up -d</code> — starts MySQL and loads the schema</li>
            <li><code>./start.sh</code> — starts the PHP server at <a href="http://localhost:8888" target="_blank" rel="noopener">localhost:8000</a></li>
          </ol>
          <p class="run-local-note">Requires: PHP, Docker (for MySQL). The iframe above shows the live app when it's running.</p>
        </div>
      )}
      <a href="https://github.com/cuberhaus/tenda_online" target="_blank" rel="noopener noreferrer" class="demo-link">
        View source on GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(6,182,212,0.1));
    border: 1px solid rgba(16,185,129,0.25);
    color: #10b981;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #10b981, #06b6d4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .demo-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }
  .demo-lead strong { color: var(--text-primary, #e4e4e7); }

  .tenda-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .tenda-local-section {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    margin-bottom: 0;
  }

  .tenda-local-header {
    padding: 1rem 1.5rem;
    background: rgba(99, 102, 241, 0.08);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .tenda-local-header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .tenda-local-hint {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
    min-width: 200px;
  }

  .tenda-local-hint code {
    font-size: 0.75rem;
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }

  .tenda-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-start);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .tenda-open-btn:hover {
    color: var(--accent-end);
    background: var(--bg-card-hover);
  }

  .tenda-iframe {
    width: 100%;
    height: 600px;
    min-height: 500px;
    border: none;
    display: block;
  }

  .run-local-box {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-start);
  }

  .run-local-box h4 { margin-bottom: 0.5rem; font-size: 0.95rem; }

  .run-local-box ol {
    margin: 0.5rem 0 0 1.25rem;
    padding: 0;
  }

  .run-local-box li {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .run-local-box code {
    background: var(--bg-card);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
  }

  .run-local-note {
    margin: 0.75rem 0 0 !important;
    font-size: 0.8rem !important;
    color: var(--text-muted) !important;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-start);
    transition: color var(--transition-fast);
  }

  .demo-link:hover { color: var(--accent-end); }
</style>
