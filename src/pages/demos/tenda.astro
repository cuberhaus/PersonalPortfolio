---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import TendaDemo from '../../components/demos/TendaDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';
import { getTendaCopy } from '../../i18n/demos/tenda-page';

const lang = getLangFromUrl(Astro.url);
const demo = getDemo('tenda', lang);
const tr = getTendaCopy(lang);
const t = useTranslations(lang);
---

<DemoLayout title={demo.metaTitle ?? demo.title} description={demo.metaDescription} slug="tenda">
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/tenda_online"
      githubLabel={t('demo.viewSource')}
      accentFrom="#10b981"
      accentTo="#06b6d4"
    />

    <LiveAppEmbed
      url="http://localhost:8888"
      title="Tenda Online"
      dockerCmd="cd tenda_online && docker compose up -d && ./start.sh"
      lang={lang}
      fallbackSelector="#tenda-mock-fallback"
      client:load
    />

    <div id="tenda-mock-fallback" class="tenda-demo-wrapper">
      <TendaDemo lang={lang} client:visible />
    </div>

    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p>{demo.aboutDescription}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .tenda-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
