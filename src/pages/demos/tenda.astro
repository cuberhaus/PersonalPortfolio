---
import DemoLayout from '../../layouts/DemoLayout.astro';
---

<DemoLayout title="Tenda Online" description="A full PHP e-commerce store with product browsing, cart, and checkout.">
  <div class="container">
    <div class="demo-header">
      <h1>Tenda Online</h1>
      <p class="demo-lead">
        A fully functional e-commerce store built with PHP and MySQL. Browse products by category,
        add items to your cart, and go through the checkout flow.
      </p>
    </div>

    <div class="iframe-wrapper">
      <div class="iframe-placeholder">
        <div class="placeholder-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3>Live Demo Coming Soon</h3>
        <p>
          This PHP/MySQL application requires server-side hosting.
          The live demo will be embedded here once deployed.
        </p>
        <p class="placeholder-tech">
          Built with: PHP, MySQL, HTML/CSS
        </p>
        <!-- Replace the placeholder with an iframe once deployed:
        <iframe src="https://your-tenda-host.example.com" title="Tenda Online" class="demo-iframe" allowfullscreen></iframe>
        -->
      </div>
    </div>

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        A complete e-commerce platform with product catalog, category browsing, shopping cart,
        checkout flow, and an admin order management panel. Features include dynamic product pages,
        cart persistence, and order processing.
      </p>
      <a href="https://github.com/cuberhaus/tenda_online" target="_blank" rel="noopener noreferrer" class="demo-link">
        View source on GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .demo-lead {
    color: var(--text-secondary);
    max-width: 680px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .iframe-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    min-height: 400px;
  }

  .demo-iframe {
    width: 100%;
    height: 600px;
    border: none;
    display: block;
  }

  .iframe-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    min-height: 400px;
  }

  .placeholder-icon {
    color: var(--accent-start);
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .iframe-placeholder h3 {
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }

  .iframe-placeholder p {
    color: var(--text-muted);
    max-width: 400px;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .placeholder-tech {
    font-family: var(--font-mono);
    font-size: 0.75rem !important;
    color: var(--text-muted) !important;
    opacity: 0.6;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-start);
    transition: color var(--transition-fast);
  }

  .demo-link:hover { color: var(--accent-end); }
</style>
