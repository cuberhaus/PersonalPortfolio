---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import TendaDemo from '../../components/demos/TendaDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const demo = getDemo('tenda', lang);
const t = useTranslations(lang);
---

<DemoLayout
  title={demo.metaTitle ?? demo.title}
  description={demo.metaDescription}
  slug="tenda"
  ogImage="/og/tenda-og.png"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={demo.github}
      githubLabel={t('demo.viewSource')}
      accent={demo.accent}
    />

    <LiveAppEmbed
      slug="tenda"
      title="Tenda Online"
      lang={lang}
      fallbackSelector="#tenda-mock-fallback"
      client:load
    />

    <div id="tenda-mock-fallback" class="tenda-demo-wrapper">
      <TendaDemo lang={lang} client:visible />
    </div>

    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p>{demo.aboutDescription}</p>
    </div>
  </div>
</DemoLayout>

<style>
  .tenda-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 {
    margin-bottom: 0.75rem;
  }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
</style>
