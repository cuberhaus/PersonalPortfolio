---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import PlanificacionDemo from '../../components/demos/PlanificacionDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('planificacion', lang);
---

<DemoLayout
  title={demo.metaTitle ?? demo.title}
  description={demo.metaDescription}
  slug="planificacion"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/Practica_de_Planificacion"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#a855f7"
    />

    <PlanificacionDemo lang={lang} client:visible />
  </div>
</DemoLayout>

<style>
  :global(.demo-hdr-lead code) {
    font-size: 0.9em;
    background: var(--bg-secondary);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
</style>
