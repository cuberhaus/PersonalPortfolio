---
import DemoLayout from '../../layouts/DemoLayout.astro';
import PlanificacionDemo from '../../components/demos/PlanificacionDemo';
---

<DemoLayout
  title="Travel Agency Planning (PDDL)"
  description="PDDL domain for automated travel planning: flights, hotels, duration constraints, and numeric optimization. Interactive planner demo."
>
  <div class="container">
    <div class="demo-header">
      <div class="badge">Automated Planning · FIB-UPC</div>
      <h1>Pràctica de Planificació</h1>
      <p class="demo-lead">
        A <strong>PDDL</strong> model of a travel agency: flights, hotels, stay duration, and a numeric
        <strong>interest metric</strong> to minimize. Browse the Extension 2 domain, download
        <code>.pddl</code> files, or run the planner when an ENHSP backend is deployed.
      </p>
    </div>

    <PlanificacionDemo client:load />
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(168,85,247,0.1));
    border: 1px solid rgba(99,102,241,0.25);
    color: #6366f1;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: #a1a1aa;
    font-size: 1rem;
    line-height: 1.7;
    max-width: 40rem;
    margin: 0 auto;
  }
  .demo-lead strong { color: #e4e4e7; }
  .demo-lead code {
    font-size: 0.9em;
    background: rgba(99, 102, 241, 0.12);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
</style>
