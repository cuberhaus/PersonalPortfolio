---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import FibDemo from '../../components/demos/FibDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('algorithms', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="algorithms"
  ogImage="/og/algorithms-og.png"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={demo.github}
      githubLabel={t('demo.viewSource')}
      accent={demo.accent}
    />

    <LiveAppEmbed
      slug="algorithms"
      title="Algorithm Visualizer"
      lang={lang}
      fallbackSelector="#fib-mock-fallback"
      client:load
    />

    <div id="fib-mock-fallback">
      <FibDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>
