---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import FibDemo from '../../components/demos/FibDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('algorithms', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="algorithms"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/fib"
      githubLabel={t('demo.viewSource')}
      accentFrom="#a78bfa"
      accentTo="#22d3ee"
    />

    <LiveAppEmbed
      url="http://localhost:8090"
      title="Algorithm Visualizer"
      dockerCmd="cd fib && docker compose up -d"
      devCmd="cd fib/web && npm run dev"
      lang={lang}
      fallbackSelector="#fib-mock-fallback"
      client:load
    />

    <div id="fib-mock-fallback">
      <FibDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>
