---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';
import { getJocEdaCopy } from '../../i18n/demos/joc-eda-page';

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const demo = getDemo('joc-eda', lang);
const tr = getJocEdaCopy(lang);
const t = useTranslations(lang);
---

<DemoLayout title={demo.metaTitle ?? demo.title} description={demo.metaDescription} slug="joc-eda">
  <div class="container joc-eda-page">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/joc_eda"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#f59e0b"
    />

    <LiveAppEmbed
      url="http://localhost:8087"
      title="ThePurge Viewer"
      dockerCmd="cd joc_eda && docker compose up -d"
      devCmd="cd joc_eda && make web-dev"
      lang={lang}
      client:load
    />

    <div class="cards-row">
      <!-- Sample game card -->
      <div class="game-card">
        <div class="game-card-badge">{tr.preloaded}</div>
        <div class="game-card-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </div>
        <h3>{tr.sampleTitle}</h3>
        <p>{tr.sampleDesc}</p>
        <div class="game-meta">
          <span><strong>{tr.map}</strong> 15 × 30</span>
          <span><strong>{tr.rounds}</strong> 250</span>
          <span><strong>{tr.players}</strong> 4</span>
        </div>
        <a id="launch-sample" class="launch-btn" href="#" target="_blank" rel="noopener noreferrer">
          {tr.watchReplay}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
      </div>

      <!-- Upload card -->
      <div class="game-card upload-card">
        <div class="game-card-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
          </svg>
        </div>
        <h3>{tr.ownGame}</h3>
        <p set:html={tr.uploadDesc}></p>
        <div class="upload-instructions">
          <code>make && ./Game &lt; default.cnf &gt; replay.out</code>
        </div>
        <label class="launch-btn upload-btn" for="file-upload">
          {tr.uploadBtn}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
          </svg>
        </label>
        <input type="file" id="file-upload" accept=".out,.txt" style="display:none" />
        <div id="upload-status" class="upload-status" 
             data-msg-reading={tr.readingFile} 
             data-msg-invalid={tr.invalidFile} 
             data-msg-loaded={tr.loadedFile} 
             data-msg-toolarge={tr.fileTooLarge}></div>
      </div>
    </div>

    <!-- Controls reference -->
    <div class="controls-card">
      <h3>{tr.controls}</h3>
      <div class="controls-grid">
        <div class="control-item"><kbd>Space</kbd><span>{tr.playPause}</span></div>
        <div class="control-item"><kbd>←</kbd> <kbd>→</kbd><span>{tr.prevNext}</span></div>
        <div class="control-item"><kbd>Home</kbd> <kbd>End</kbd><span>{tr.startEnd}</span></div>
        <div class="control-item"><kbd>Mouse wheel</kbd><span>{tr.zoom}</span></div>
        <div class="control-item"><kbd>Slider</kbd><span>{tr.scrub}</span></div>
        <div class="control-item"><kbd>H</kbd><span>{tr.help}</span></div>
      </div>
    </div>

    <!-- About -->
    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p set:html={demo.aboutDescription}></p>
      <h4>{tr.howTo}</h4>
      <ol class="steps-list">
        <li set:html={tr.step1}></li>
        <li set:html={tr.step2}></li>
        <li set:html={tr.step3}></li>
        <li set:html={tr.step4}></li>
        <li set:html={tr.step5}></li>
      </ol>
      
    </div>
  </div>
</DemoLayout>

<script>
  const base = document.querySelector('link[rel="icon"]')?.getAttribute('href')?.replace('/favicon.svg', '') || '';
  const viewerBase = `${base}/demos/joc-eda/viewer.html`;

  // Sample game launcher
  document.getElementById('launch-sample')!.setAttribute('href', viewerBase);

  // File upload handler
  const fileInput = document.getElementById('file-upload') as HTMLInputElement;
  const statusEl = document.getElementById('upload-status')!;

  fileInput.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    statusEl.textContent = statusEl.dataset.msgReading || 'Reading file...';
    statusEl.style.color = '#a1a1aa';

    const reader = new FileReader();
    reader.onload = () => {
      const text = reader.result as string;
      if (!text.includes('ThePurge')) {
        statusEl.textContent = statusEl.dataset.msgInvalid || 'Invalid file.';
        statusEl.style.color = '#f87171';
        return;
      }
      // Store in sessionStorage and open viewer with a flag
      try {
        sessionStorage.setItem('joc_eda_custom_game', text);
        const msgTpl = statusEl.dataset.msgLoaded || 'Loaded "{0}"';
        statusEl.textContent = msgTpl.replace('{0}', file.name);
        statusEl.style.color = '#4ade80';
        window.open(`${viewerBase}?custom=1`, '_blank');
      } catch (err) {
        statusEl.textContent = statusEl.dataset.msgToolarge || 'File too large.';
        statusEl.style.color = '#f87171';
      }
    };
    reader.readAsText(file);
  });
</script>

<style is:global>
  .joc-eda-page .cards-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .joc-eda-page .game-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .joc-eda-page .game-card:hover {
    border-color: var(--accent-start);
    box-shadow: 0 8px 30px var(--glow-color);
  }

  .joc-eda-page .game-card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-start);
    background: color-mix(in srgb, var(--accent-start) 10%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .joc-eda-page .game-card-icon {
    color: var(--accent-start);
    margin-bottom: 1.25rem;
  }

  .joc-eda-page .game-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.65rem;
  }

  .joc-eda-page .game-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1rem;
  }

  .joc-eda-page .game-card code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--bg-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    color: var(--text-secondary);
  }

  .joc-eda-page .game-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .joc-eda-page .game-meta strong {
    color: var(--text-secondary);
  }

  .joc-eda-page .upload-instructions {
    margin-bottom: 1.25rem;
  }

  .joc-eda-page .upload-instructions code {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--bg-secondary);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow-x: auto;
  }

  .joc-eda-page .launch-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: #fff;
    background: linear-gradient(135deg, var(--accent-start), var(--accent-end));
    border-radius: var(--radius-md);
    text-decoration: none;
    cursor: pointer;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    border: none;
  }

  .joc-eda-page .launch-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--glow-color-strong);
  }

  .joc-eda-page .upload-btn {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  .joc-eda-page .upload-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-start);
    box-shadow: 0 6px 20px var(--glow-color);
  }

  .joc-eda-page .upload-status {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    min-height: 1.2rem;
  }

  .joc-eda-page .controls-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .joc-eda-page .controls-card h3 {
    font-size: 1rem;
    margin-bottom: 1.25rem;
  }

  .joc-eda-page .controls-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .joc-eda-page .control-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
  }

  .joc-eda-page .control-item kbd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--bg-secondary);
    padding: 0.15rem 0.45rem;
    border-radius: 0.25rem;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    width: fit-content;
  }

  .joc-eda-page .control-item span {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .joc-eda-page .demo-info {
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .joc-eda-page .demo-info h3 { margin-bottom: 0.75rem; }
  .joc-eda-page .demo-info h4 {
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }

  .joc-eda-page .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .joc-eda-page .demo-info code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--bg-secondary);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    color: var(--text-secondary);
  }

  .joc-eda-page .steps-list {
    list-style: decimal;
    padding-left: 1.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 2;
    margin-bottom: 1.5rem;
  }

  .joc-eda-page .steps-list a {
    color: var(--accent-start);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

      @media (max-width: 768px) {
    .joc-eda-page .cards-row { grid-template-columns: 1fr; }
    .joc-eda-page .controls-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
