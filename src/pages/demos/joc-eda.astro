const tr = TRANSLATIONS[lang] || TRANSLATIONS.en;
const t = useTranslations(lang);

const metaDescs = {
  en: TRANSLATIONS.en.desc,
  es: TRANSLATIONS.es.desc,
  ca: TRANSLATIONS.ca.desc
