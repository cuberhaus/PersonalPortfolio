---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import MPIDSDemo from '../../components/demos/MPIDSDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('mpids', lang);
---

<DemoLayout title={demo.title} description={demo.metaDescription} slug="mpids">
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/projectA"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#a855f7"
    />

    <LiveAppEmbed
      slug="mpids"
      title="MPIDS Solver"
      dockerCmd="cd projectA && docker compose up -d"
      devCmd="cd projectA && make dev"
      lang={lang}
      client:load
    />

    <MPIDSDemo lang={lang} client:visible />

    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p>{demo.aboutDescription}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 {
    margin-bottom: 0.75rem;
  }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
