---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import ApaPracticaDemo from '../../components/demos/ApaPracticaDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "Hypothyroid Classification",
  es: "Clasificación de Hipotiroidismo",
  ca: "Classificació d'Hipotiroïdisme"
};

const leads = {
  en: "End-to-end binary classification pipeline — predict hypothyroidism from clinical data using <strong>9 model families</strong> in sklearn. The interactive demos below run <strong>real trained models</strong> directly in your browser.",
  es: "Pipeline de clasificación binaria de principio a fin — predice el hipotiroidismo a partir de datos clínicos utilizando <strong>9 familias de modelos</strong> en sklearn. Las demostraciones interactivas a continuación ejecutan <strong>modelos entrenados reales</strong> directamente en tu navegador.",
  ca: "Pipeline de classificació binària de principi a fi — prediu l'hipotiroïdisme a partir de dades clíniques utilitzant <strong>9 famílies de models</strong> en sklearn. Les demostracions interactives a continuació executen <strong>models entrenats reals</strong> directament al teu navegador."
};

const badges = {
  en: "Machine Learning · FIB-UPC",
  es: "Machine Learning · FIB-UPC",
  ca: "Machine Learning · FIB-UPC"
};

const metaTitles = {
  en: "Machine Learning — Hypothyroid",
  es: "Machine Learning — Hipotiroidismo",
  ca: "Machine Learning — Hipotiroïdisme"
};

const metaDescs = {
  en: "End-to-end ML pipeline for hypothyroidism detection: EDA, imputation, 9 sklearn model families compared. Interactive browser demo with real trained model.",
  es: "Pipeline de ML de principio a fin para detección de hipotiroidismo: EDA, imputación, 9 familias de modelos sklearn comparadas. Demo interactiva con modelo entrenado real.",
  ca: "Pipeline de ML de principi a fi per a detecció d'hipotiroïdisme: EDA, imputació, 9 famílies de models sklearn comparades. Demo interactiva amb model entrenat real."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout
  title={metaTitles[lang] || metaTitles.en}
  description={metaDescs[lang] || metaDescs.en}
  slug="apa-practica"
>
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/APA_Practica"
      githubLabel={t('demo.viewSource')}
      accentFrom="#818cf8"
      accentTo="#2dd4bf"
    />

    <ApaPracticaDemo lang={lang} client:visible />
  </div>
</DemoLayout>
