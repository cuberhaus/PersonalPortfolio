---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import ApaPracticaDemo from '../../components/demos/ApaPracticaDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('apa-practica', lang);
---

<DemoLayout
  title={demo.metaTitle ?? demo.title}
  description={demo.metaDescription}
  slug="apa-practica"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={demo.github}
      githubLabel={t('demo.viewSource')}
      accent={demo.accent}
    />

    <ApaPracticaDemo lang={lang} client:visible />
  </div>
</DemoLayout>
