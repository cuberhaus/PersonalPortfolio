---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import ParDemo from '../../components/demos/ParDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('par-parallel', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="par-parallel"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/PAR"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#06b6d4"
    />

    <LiveAppEmbed
      slug="par-parallel"
      title="PAR Parallel Computing"
      dockerCmd="cd PAR && docker compose up -d"
      devCmd="cd PAR && make dev"
      lang={lang}
      fallbackSelector="#par-mock-fallback"
      client:load
    />

    <div id="par-mock-fallback">
      <ParDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>
