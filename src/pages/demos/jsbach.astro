---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import JSBachDemo from '../../components/demos/JSBachDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "JSBach Interpreter",
  es: "Intérprete JSBach",
  ca: "Intèrpret JSBach"
};

const leads = {
  en: "Write <strong>music with code</strong>. JSBach is a custom programming language where you can define procedures, use variables, loops, and conditionals \u2014 and play <strong>musical notes</strong>. Try the examples or write your own!",
  es: "Escribe <strong>música con código</strong>. JSBach es un lenguaje de programación personalizado donde puedes definir procedimientos, usar variables, bucles y condicionales \u2014 y reproducir <strong>notas musicales</strong>. \u00a1Prueba los ejemplos o escribe el tuyo propio!",
  ca: "Escriu <strong>música amb codi</strong>. JSBach és un llenguatge de programació personalitzat on pots definir procediments, utilitzar variables, bucles i condicionals \u2014 i reproduir <strong>notes musicals</strong>. Prova els exemples o escriu el teu propi!"
};

const badges = {
  en: "Compilers \u00b7 FIB-UPC",
  es: "Compiladores \u00b7 FIB-UPC",
  ca: "Compiladors \u00b7 FIB-UPC"
};

const hints = {
  en: ["play a note", "print", "assign", "block"],
  es: ["toca una nota", "imprimir", "asignar", "bloque"],
  ca: ["toca una nota", "imprimir", "assignar", "bloc"]
};

const aboutTitle = {
  en: "About this project",
  es: "Sobre este proyecto",
  ca: "Sobre aquest projecte"
};

const aboutDesc = {
  en: "Originally built with ANTLR4 and Python for a compilers course at FIB-UPC. The language supports procedures, recursion, arithmetic, lists, conditionals, loops, and musical note playback. This browser version uses a hand-written parser and the Web Audio API for sound synthesis.",
  es: "Originalmente construido con ANTLR4 y Python para un curso de compiladores en la FIB-UPC. El lenguaje soporta procedimientos, recursión, aritmética, listas, condicionales, bucles y reproducción de notas musicales. Esta versión para navegador utiliza un parser escrito a mano y la Web Audio API para la síntesis de sonido.",
  ca: "Originalment construït amb ANTLR4 i Python per a un curs de compiladors a la FIB-UPC. El llenguatge suporta procediments, recursió, aritmètica, llistes, condicionals, bucles i reproducció de notes musicals. Aquesta versió per a navegador utilitza un parser escrit a mà i la Web Audio API per a la síntesi de so."
};

const metaDescs = {
  en: "Write and play music with the JSBach programming language, right in your browser.",
  es: "Escribe y reproduce música con el lenguaje de programación JSBach, directamente en tu navegador.",
  ca: "Escriu i reprodueix música amb el llenguatge de programació JSBach, directament al teu navegador."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
const hint = hints[lang] || hints.en;
---

<DemoLayout title={title} description={metaDescs[lang] || metaDescs.en} slug="jsbach">
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/ANTLR4_JSBach"
      githubLabel={t('demo.viewSource')}
      accentFrom="#f59e0b"
      accentTo="#f97316"
    >
      <div class="syntax-hints">
        <code>&lt;:&gt; C4</code> {hint[0]} &nbsp;
        <code>&lt;!&gt; "text"</code> {hint[1]} &nbsp;
        <code>x &lt;- 5</code> {hint[2]} &nbsp;
        <code>|: ... :|</code> {hint[3]}
      </div>
    </DemoHeader>

    <JSBachDemo lang={lang} client:visible />

    <div class="demo-info">
      <h3>{aboutTitle[lang] || aboutTitle.en}</h3>
      <p>{aboutDesc[lang] || aboutDesc.en}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .syntax-hints {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .syntax-hints code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
