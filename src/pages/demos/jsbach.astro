---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import JSBachDemo from '../../components/demos/JSBachDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('jsbach', lang);
const hint = demo.hints ?? [];
---

<DemoLayout title={demo.title} description={demo.metaDescription} slug="jsbach">
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/ANTLR4_JSBach"
      githubLabel={t('demo.viewSource')}
      accentFrom="#f59e0b"
      accentTo="#f97316"
    >
      <div class="syntax-hints">
        <code>&lt;:&gt; C4</code> {hint[0]} &nbsp;
        <code>&lt;!&gt; "text"</code> {hint[1]} &nbsp;
        <code>x &lt;- 5</code> {hint[2]} &nbsp;
        <code>|: ... :|</code> {hint[3]}
      </div>
    </DemoHeader>

    <JSBachDemo lang={lang} client:visible />

    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p>{demo.aboutDescription}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .syntax-hints {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .syntax-hints code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
