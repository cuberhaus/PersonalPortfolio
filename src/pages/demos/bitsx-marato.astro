---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import BitsXMaratoDemo from '../../components/demos/BitsXMaratoDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titles = {
  en: "Aorta Detection",
  es: "Detección de Aorta",
  ca: "Detecció d'Aorta"
};

const leads = {
  en: "Run the aorta pipeline live: abdominal ultrasound → <strong>Mask R-CNN</strong> segmentation → <strong>3D mesh</strong> reconstruction → aortic <strong>diameter</strong> estimation. Built for the <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a> hackathon.",
  es: "Ejecuta el pipeline de la aorta en vivo: ecografía abdominal → segmentación <strong>Mask R-CNN</strong> → reconstrucción de <strong>malla 3D</strong> → estimación del <strong>diámetro</strong> aórtico. Construido para la hackathon <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a>.",
  ca: "Executa el pipeline de l'aorta en viu: ecografia abdominal → segmentació <strong>Mask R-CNN</strong> → reconstrucció de <strong>malla 3D</strong> → estimació del <strong>diàmetre</strong> aòrtic. Construït per a la hackató <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a>."
};

const badges = {
  en: "Computer Vision · Hackathon",
  es: "Visión por Computador · Hackathon",
  ca: "Visió per Computador · Hackató"
};

const metaTitles = {
  en: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)",
  es: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)",
  ca: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)"
};

const metaDescs = {
  en: "BitsXLaMarató 2022 winner: Mask R-CNN aorta segmentation and 3D reconstruction for aneurysm detection. Interactive PyTorch + OpenCV inference demo.",
  es: "Ganador de BitsXLaMarató 2022: segmentación de aorta con Mask R-CNN y reconstrucción 3D para detección de aneurismas. Demo interactiva de inferencia con PyTorch + OpenCV.",
  ca: "Guanyador de BitsXLaMarató 2022: segmentació d'aorta amb Mask R-CNN i reconstrucció 3D per a detecció d'aneurismes. Demo interactiva d'inferència amb PyTorch + OpenCV."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout
  title={metaTitles[lang] || metaTitles.en}
  description={metaDescs[lang] || metaDescs.en}
  slug="bitsx-marato"
>
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/bitsXlaMarato"
      githubLabel={t('demo.viewSource')}
      accentFrom="#be123c"
      accentTo="#0ea5e9"
    />

    <BitsXMaratoDemo lang={lang} client:visible />
  </div>
</DemoLayout>

<style>
  :global(.demo-hdr-lead a) {
    color: var(--accent-end);
    text-decoration: none;
  }
  :global(.demo-hdr-lead a:hover) {
    text-decoration: underline;
  }
</style>
