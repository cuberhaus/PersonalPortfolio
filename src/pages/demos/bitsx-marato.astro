---
import DemoLayout from '../../layouts/DemoLayout.astro';
import BitsXMaratoDemo from '../../components/demos/BitsXMaratoDemo';
---

<DemoLayout
  title="BitsXLaMarató — Aorta / AAA (Mask R-CNN)"
  description="Ultrasound segmentation with Mask R-CNN, 3D aorta reconstruction, and diameter estimation for AAA research."
>
  <div class="container">
    <div class="demo-header">
      <h1>BitsXLaMarató — Aorta detection</h1>
      <p class="demo-lead">
        Hackathon project: abdominal ultrasound → <strong>Mask R-CNN</strong> aorta masks → <strong>3D mesh</strong> and
        <strong>diameter</strong> heuristics. Open the <strong>Interactive</strong> tab for a browser mock; full pipeline runs in Python (
        <a href="https://github.com/cuberhaus/bitsXlaMarato" target="_blank" rel="noopener noreferrer">bitsXlaMarato</a>
        ).
      </p>
    </div>

    <BitsXMaratoDemo client:load />
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    background: linear-gradient(135deg, #f43f5e, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .demo-lead {
    color: #a1a1aa;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 40rem;
    margin: 0 auto;
  }
  .demo-lead a {
    color: #38bdf8;
  }
</style>
