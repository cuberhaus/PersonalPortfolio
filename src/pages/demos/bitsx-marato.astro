---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import BitsXMaratoDemo from '../../components/demos/BitsXMaratoDemo';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const viewSource = {
  en: 'View Source on GitHub',
  es: 'Ver código en GitHub',
  ca: 'Veure codi a GitHub',
};
const githubLabel = viewSource[lang] || 'View Source on GitHub';

const titles = {
  en: "Aorta Detection",
  es: "Detección de Aorta",
  ca: "Detecció d'Aorta"
};

const leads = {
  en: "Abdominal ultrasound → <strong>Mask R-CNN</strong> segmentation → <strong>3D mesh</strong> reconstruction → aortic <strong>diameter</strong> estimation. Built for the <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a> hackathon.",
  es: "Ecografía abdominal → segmentación <strong>Mask R-CNN</strong> → reconstrucción <strong>malla 3D</strong> → estimación del <strong>diámetro</strong> aórtico. Construido para la hackathon <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a>.",
  ca: "Ecografia abdominal → segmentació <strong>Mask R-CNN</strong> → reconstrucció <strong>malla 3D</strong> → estimació del <strong>diàmetre</strong> aòrtic. Construït per a la hackató <a href=\"https://www.ccma.cat/tv3/marato/\" target=\"_blank\" rel=\"noopener noreferrer\">BitsXLaMarató</a>."
};

const badges = {
  en: "Computer Vision · Hackathon",
  es: "Visión por Computador · Hackathon",
  ca: "Visió per Computador · Hackató"
};

const metaTitles = {
  en: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)",
  es: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)",
  ca: "BitsXLaMarató — Aorta / AAA (Mask R-CNN)"
};

const metaDescs = {
  en: "Hackathon project: abdominal ultrasound → Mask R-CNN aorta masks → 3D mesh and diameter heuristics. Interactive browser mock of the inference pipeline.",
  es: "Proyecto de hackathon: ecografía abdominal → máscaras Mask R-CNN de aorta → malla 3D y heurísticas de diámetro. Mock interactivo del pipeline de inferencia.",
  ca: "Projecte de hackató: ecografia abdominal → màscares Mask R-CNN d'aorta → malla 3D i heurístiques de diàmetre. Mock interactiu del pipeline d'inferència."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout
  title={metaTitles[lang] || metaTitles.en}
  description={metaDescs[lang] || metaDescs.en}
  slug="bitsx-marato"
>
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl="https://github.com/cuberhaus/bitsXlaMarato"
      githubLabel={githubLabel}
      accentFrom="#be123c"
      accentTo="#0ea5e9"
    />

    <BitsXMaratoDemo lang={lang} client:visible />
  </div>
</DemoLayout>

<style>
  :global(.demo-hdr-lead a) {
    color: var(--accent-end);
    text-decoration: none;
  }
  :global(.demo-hdr-lead a:hover) {
    text-decoration: underline;
  }
</style>
