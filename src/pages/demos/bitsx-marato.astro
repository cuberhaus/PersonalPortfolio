---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import BitsXMaratoDemo from '../../components/demos/BitsXMaratoDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('bitsx-marato', lang);
---

<DemoLayout
  title={demo.metaTitle ?? demo.title}
  description={demo.metaDescription}
  slug="bitsx-marato"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/bitsXlaMarato"
      githubLabel={t('demo.viewSource')}
      accentFrom="#be123c"
      accentTo="#0ea5e9"
    />

    <BitsXMaratoDemo lang={lang} client:visible />
  </div>
</DemoLayout>

<style>
  :global(.demo-hdr-lead a) {
    color: var(--accent-end);
    text-decoration: none;
  }
  :global(.demo-hdr-lead a:hover) {
    text-decoration: underline;
  }
</style>
