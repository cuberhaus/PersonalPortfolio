---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DraculinDemo from '../../components/demos/DraculinDemo';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isDev = import.meta.env.DEV;

const titles = {
  en: "Draculin",
  es: "Draculin",
  ca: "Draculin"
};

const leads = {
  en: "A mobile health app combining an <strong>AI chatbot</strong> with <strong>computer vision</strong> for menstrual health tracking. Finalist at <strong>BitsXLaMarató 2023</strong>.",
  es: "Una app de salud móvil que combina un <strong>chatbot de IA</strong> con <strong>visión por computador</strong> para el seguimiento de la salud menstrual. Finalista en <strong>BitsXLaMarató 2023</strong>.",
  ca: "Una app de salut mòbil que combina un <strong>chatbot d'IA</strong> amb <strong>visió per computador</strong> per al seguiment de la salut menstrual. Finalista a <strong>BitsXLaMarató 2023</strong>."
};

const badges = {
  en: "Mobile Health \u00b7 Hackathon",
  es: "Salud Móvil \u00b7 Hackathon",
  ca: "Salut Mòbil \u00b7 Hackathon"
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout title="Draculin" description="Health tracking app with AI chatbot and computer vision, built with Flutter." slug="draculin">
  <div class="container">
    <div class="demo-header">
      <div class="badge">{badge}</div>
      <h1>{title}</h1>
      <p class="demo-lead" set:html={lead} />
      <div class="demo-header-actions">
        {(() => {
          const vs_front = { en: "Frontend Code (GitHub)", es: "Código Frontend (GitHub)", ca: "Codi Frontend (GitHub)" };
          const vs_back = { en: "Backend Code (GitHub)", es: "Código Backend (GitHub)", ca: "Codi Backend (GitHub)" };
          return (
            <>
            <a href="https://github.com/cuberhaus/Draculin-Front" class="demo-header-github" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              {vs_front[lang] || vs_front.en}
            </a>
            <a href="https://github.com/cuberhaus/Draculin-Backend" class="demo-header-github" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              {vs_back[lang] || vs_back.en}
            </a>
            </>
          );
        })()}
      </div>
    </div>

    {isDev ? (
      <div class="draculin-local-section">
        <div class="draculin-local-header">
          <h3>Live Flutter app (runs locally)</h3>
          <p class="draculin-local-hint">
            Start it: <code>cd Draculin-Backend && docker compose up -d</code>
          </p>
          <a href="http://localhost:8890" target="_blank" rel="noopener noreferrer" class="draculin-open-btn">
            Open in new tab
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
          </a>
        </div>
        <div class="phone-frame-container">
          <div class="phone-frame">
            <div class="phone-notch"></div>
            <iframe
              src="http://localhost:8890"
              title="Draculin Flutter App"
              class="draculin-iframe"
            />
          </div>
        </div>
      </div>
    ) : (
      <div class="draculin-demo-wrapper">
        <DraculinDemo lang={lang} client:load />
      </div>
    )}

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        Draculin was developed for the BitsXLaMarató 2023 hackathon, where it reached the finals.
        The app uses a Google LLM-powered chatbot for health guidance and computer vision to analyze
        images for menstrual health tracking. The frontend is built with Flutter (supporting iOS,
        Android, and web), while the backend runs on Django with image inference capabilities.
      </p>
      {isDev && (
        <div class="run-local-box">
          <h4>Run the real app locally</h4>
          <ol>
            <li><code>cd Draculin-Backend</code></li>
            <li><code>docker compose up -d</code> — builds and starts the Django backend (port 8889) and Flutter web frontend (port 8890)</li>
          </ol>
          <p class="run-local-note">Requires: Docker. The chatbot and vision features run in mock mode without API keys.</p>
        </div>
      )}
      
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(236,72,153,0.15), rgba(168,85,247,0.1));
    border: 1px solid rgba(236,72,153,0.25);
    color: #ec4899;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #ec4899, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .demo-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto;
    line-height: 1.7;
    font-size: 1rem;
  }
  .demo-lead strong { color: var(--text-primary, #e4e4e7); }

  .draculin-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .draculin-local-section {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    margin-bottom: 0;
  }

  .draculin-local-header {
    padding: 1rem 1.5rem;
    background: rgba(99, 102, 241, 0.08);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .draculin-local-header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .draculin-local-hint {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
    min-width: 200px;
  }

  .draculin-local-hint code {
    font-size: 0.75rem;
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }

  .draculin-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-start);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .draculin-open-btn:hover {
    color: var(--accent-end);
    background: var(--bg-card-hover);
  }

  .phone-frame-container {
    display: flex;
    justify-content: center;
    padding: 2rem 1rem;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(168, 85, 247, 0.05));
  }

  .phone-frame {
    position: relative;
    width: 375px;
    height: 750px;
    border-radius: 2.5rem;
    border: 4px solid #333;
    background: #000;
    box-shadow:
      0 0 0 2px var(--border-color),
      0 20px 60px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 140px;
    height: 28px;
    background: #000;
    border-radius: 0 0 1.25rem 1.25rem;
    z-index: 10;
  }

  .draculin-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    border-radius: 2.25rem;
  }

  .run-local-box {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-start);
  }

  .run-local-box h4 { margin-bottom: 0.5rem; font-size: 0.95rem; }

  .run-local-box ol {
    margin: 0.5rem 0 0 1.25rem;
    padding: 0;
  }

  .run-local-box li {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .run-local-box code {
    background: var(--bg-card);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
  }

  .run-local-note {
    margin: 0.75rem 0 0 !important;
    font-size: 0.8rem !important;
    color: var(--text-muted) !important;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

      </style>
