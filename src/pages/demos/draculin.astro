---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DraculinDemo from '../../components/demos/DraculinDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('draculin', lang);
---

<DemoLayout title={demo.title} description={demo.metaDescription} slug="draculin">
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={["https://github.com/cuberhaus/Draculin-Front", "https://github.com/cuberhaus/Draculin-Backend"]}
      githubLabel={[t('demo.viewFrontend'), t('demo.viewBackend')]}
      accentFrom="#ec4899"
      accentTo="#a855f7"
    />

    <LiveAppEmbed
      slug="draculin"
      title="Draculin Flutter App"
      dockerCmd="cd Draculin-Backend && docker compose up -d"
      lang={lang}
      fallbackSelector="#draculin-mock-fallback"
      client:load
    />

    <div id="draculin-mock-fallback" class="draculin-demo-wrapper">
      <DraculinDemo lang={lang} client:visible />
    </div>

    <div class="demo-info">
      <h3>{demo.aboutTitle}</h3>
      <p>{demo.aboutDescription}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .draculin-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

      </style>
