---
import DemoLayout from '../../layouts/DemoLayout.astro';
---

<DemoLayout title="Draculin" description="Health tracking app with AI chatbot and computer vision, built with Flutter.">
  <div class="container">
    <div class="demo-header">
      <h1>Draculin</h1>
      <p class="demo-lead">
        A mobile health app combining an AI chatbot with computer vision for menstrual health tracking.
        Finalist at BitsXLaMarató 2023.
      </p>
    </div>

    <div class="iframe-wrapper">
      <div class="iframe-placeholder">
        <div class="placeholder-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
        </div>
        <h3>Live Demo Coming Soon</h3>
        <p>
          This Flutter app with a Django backend requires server-side hosting.
          The Flutter web build will be embedded here once deployed.
        </p>
        <p class="placeholder-tech">
          Built with: Flutter, Django, Google LLM, Computer Vision
        </p>
        <!-- Replace the placeholder with an iframe once the Flutter web build is deployed:
        <iframe src="https://your-draculin-host.example.com" title="Draculin" class="demo-iframe" allowfullscreen></iframe>
        -->
      </div>
    </div>

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        Draculin was developed for the BitsXLaMarató 2023 hackathon, where it reached the finals.
        The app uses a Google LLM-powered chatbot for health guidance and computer vision to analyze
        images for menstrual health tracking. The frontend is built with Flutter (supporting iOS,
        Android, and web), while the backend runs on Django with image inference capabilities.
      </p>
      <div class="demo-links">
        <a href="https://github.com/cuberhaus/Draculin-Front" target="_blank" rel="noopener noreferrer" class="demo-link">
          Frontend repo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
        <a href="https://github.com/cuberhaus/Draculin-Backend" target="_blank" rel="noopener noreferrer" class="demo-link">
          Backend repo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .demo-lead {
    color: var(--text-secondary);
    max-width: 680px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .iframe-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    min-height: 400px;
  }

  .demo-iframe {
    width: 100%;
    height: 600px;
    border: none;
    display: block;
  }

  .iframe-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    min-height: 400px;
  }

  .placeholder-icon {
    color: var(--accent-start);
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .iframe-placeholder h3 {
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }

  .iframe-placeholder p {
    color: var(--text-muted);
    max-width: 400px;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .placeholder-tech {
    font-family: var(--font-mono);
    font-size: 0.75rem !important;
    color: var(--text-muted) !important;
    opacity: 0.6;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .demo-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-start);
    transition: color var(--transition-fast);
  }

  .demo-link:hover { color: var(--accent-end); }
</style>
