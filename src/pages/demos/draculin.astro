---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DraculinDemo from '../../components/demos/DraculinDemo';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const titles = {
  en: "Draculin",
  es: "Draculin",
  ca: "Draculin"
};

const leads = {
  en: "Walk through <strong>Draculin</strong>: a Flutter + Django health-tracking app with an <strong>AI chatbot</strong> and <strong>computer vision</strong> assistance. <strong>BitsXLaMarató 2023</strong> finalist.",
  es: "Recorre <strong>Draculin</strong>: una app de salud en Flutter + Django con un <strong>chatbot de IA</strong> y asistencia por <strong>visión por computador</strong>. Finalista en <strong>BitsXLaMarató 2023</strong>.",
  ca: "Recorre <strong>Draculin</strong>: una app de salut en Flutter + Django amb un <strong>chatbot d'IA</strong> i assistència per <strong>visió per computador</strong>. Finalista a <strong>BitsXLaMarató 2023</strong>."
};

const badges = {
  en: "Mobile Health \u00b7 Hackathon",
  es: "Salud Móvil \u00b7 Hackathon",
  ca: "Salut Mòbil \u00b7 Hackathon"
};

const vsFront = { en: "Frontend Code (GitHub)", es: "Código Frontend (GitHub)", ca: "Codi Frontend (GitHub)" };
const vsBack = { en: "Backend Code (GitHub)", es: "Código Backend (GitHub)", ca: "Codi Backend (GitHub)" };

const metaDescs = {
  en: "Flutter + Django health-tracking app with an AI chatbot and computer vision. BitsXLaMarató 2023 finalist — browse the UI and interactive flows.",
  es: "App de seguimiento de salud en Flutter + Django con chatbot de IA y visión por computador. Finalista de BitsXLaMarató 2023 — recorre la UI y los flujos interactivos.",
  ca: "App de seguiment de salut en Flutter + Django amb chatbot d'IA i visió per computador. Finalista de BitsXLaMarató 2023 — recorre la UI i els fluxos interactius."
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout title={title} description={metaDescs[lang] || metaDescs.en} slug="draculin">
  <div class="container">
    <DemoHeader
      badge={badge}
      title={title}
      lead={lead}
      githubUrl={["https://github.com/cuberhaus/Draculin-Front", "https://github.com/cuberhaus/Draculin-Backend"]}
      githubLabel={[vsFront[lang] || vsFront.en, vsBack[lang] || vsBack.en]}
      accentFrom="#ec4899"
      accentTo="#a855f7"
    />

    <LiveAppEmbed
      url="http://localhost:8890"
      title="Draculin Flutter App"
      dockerCmd="cd Draculin-Backend && docker compose up -d"
      lang={lang}
      fallbackSelector="#draculin-mock-fallback"
      client:load
    />

    <div id="draculin-mock-fallback" class="draculin-demo-wrapper">
      <DraculinDemo lang={lang} client:visible />
    </div>

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        Draculin was developed for the BitsXLaMarató 2023 hackathon, where it reached the finals.
        The app uses a Google LLM-powered chatbot for health guidance and computer vision to analyze
        images for menstrual health tracking. The frontend is built with Flutter (supporting iOS,
        Android, and web), while the backend runs on Django with image inference capabilities.
      </p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .draculin-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

      </style>
