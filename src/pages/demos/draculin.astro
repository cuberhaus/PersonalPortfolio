---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DraculinDemo from '../../components/demos/DraculinDemo';
---

<DemoLayout title="Draculin" description="Health tracking app with AI chatbot and computer vision, built with Flutter.">
  <div class="container">
    <div class="demo-header">
      <h1>Draculin</h1>
      <p class="demo-lead">
        A mobile health app combining an AI chatbot with computer vision for menstrual health tracking.
        Finalist at BitsXLaMarató 2023.
      </p>
    </div>

    <div class="draculin-demo-wrapper">
      <DraculinDemo client:load />
    </div>

    <div class="demo-info">
      <h3>About this project</h3>
      <p>
        Draculin was developed for the BitsXLaMarató 2023 hackathon, where it reached the finals.
        The app uses a Google LLM-powered chatbot for health guidance and computer vision to analyze
        images for menstrual health tracking. The frontend is built with Flutter (supporting iOS,
        Android, and web), while the backend runs on Django with image inference capabilities.
      </p>
      <div class="demo-links">
        <a href="https://github.com/cuberhaus/Draculin-Front" target="_blank" rel="noopener noreferrer" class="demo-link">
          Frontend repo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
        <a href="https://github.com/cuberhaus/Draculin-Backend" target="_blank" rel="noopener noreferrer" class="demo-link">
          Backend repo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .demo-lead {
    color: var(--text-secondary);
    max-width: 680px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .draculin-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 { margin-bottom: 0.75rem; }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .demo-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-start);
    transition: color var(--transition-fast);
  }

  .demo-link:hover { color: var(--accent-end); }
</style>
