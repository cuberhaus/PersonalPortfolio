---
import DemoLayout from '../../layouts/DemoLayout.astro';
import PhaseTransitionsDemo from '../../components/demos/PhaseTransitionsDemo';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const titles = {
  en: "Graph Phase Transitions",
  es: "Transiciones de Fase en Grafos",
  ca: "Transicions de Fase en Grafs"
};

const leads = {
  en: "Explore how <strong>random graphs</strong> transition from connected to disconnected as you remove nodes or edges. Generate <strong>binomial</strong> (Erdős–Rényi), <strong>geometric</strong>, or <strong>grid</strong> graphs, apply percolation, and watch the phase transition happen in real time.",
  es: "Explora cómo los <strong>grafos aleatorios</strong> transicionan de conectados a desconectados a medida que eliminas nodos o aristas. Genera grafos <strong>binomiales</strong> (Erdős–Rényi), <strong>geométricos</strong> o de <strong>cuadrícula</strong>, aplica percolación y observa cómo ocurre la transición de fase en tiempo real.",
  ca: "Explora com els <strong>grafs aleatoris</strong> transicionen de connectats a desconnectats a mesura que elimines nodes o arestes. Genera grafs <strong>binomials</strong> (Erdős–Rényi), <strong>geomètrics</strong> o de <strong>quadrícula</strong>, aplica percolació i observa com ocorre la transició de fase en temps real."
};

const badges = {
  en: "Algorithmics \u00b7 FIB-UPC",
  es: "Algoritmia \u00b7 FIB-UPC",
  ca: "Algorísmia \u00b7 FIB-UPC"
};

const aboutTitles = {
  en: "About this project",
  es: "Sobre este proyecto",
  ca: "Sobre aquest projecte"
};

const aboutDescs = {
  en: "Originally a Python project for the Algorithmics course at FIB-UPC, studying phase transitions in random graphs using NetworkX. This browser demo is a port of the graph generation, percolation, and connectivity/complexity analysis to TypeScript with interactive visualization.",
  es: "Originalmente un proyecto de Python para el curso de Algoritmia en la FIB-UPC, estudiando transiciones de fase en grafos aleatorios usando NetworkX. Esta demo de navegador es un port de la generación de grafos, percolación y análisis de conectividad/complejidad a TypeScript con visualización interactiva.",
  ca: "Originalment un projecte de Python per al curs d'Algorísmia a la FIB-UPC, estudiant transicions de fase en grafs aleatoris usant NetworkX. Aquesta demo de navegador és un port de la generació de grafs, percolació i anàlisi de connectivitat/complexitat a TypeScript amb visualització interactiva."
};

const viewSource = {
  en: "View source on GitHub",
  es: "Ver código en GitHub",
  ca: "Veure codi a GitHub"
};

const title = titles[lang] || titles.en;
const lead = leads[lang] || leads.en;
const badge = badges[lang] || badges.en;
---

<DemoLayout title={title} description="Interactive percolation and phase transition explorer for random graphs.">
  <div class="container">
    <div class="demo-header">
      <div class="badge">{badge}</div>
      <h1>{title}</h1>
      <p class="demo-lead" set:html={lead} />
      <div class="demo-header-actions">
        {(() => {
          const vs = { en: "View Source on GitHub", es: "Ver código en GitHub", ca: "Veure codi a GitHub" };
          return (
            <a href="https://github.com/cuberhaus/projectA2" class="demo-header-github" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              {vs[lang] || vs.en}
            </a>
          );
        })()}
      </div>
    </div>

    <PhaseTransitionsDemo lang={lang} client:load />

    <div class="demo-info">
      <h3>{aboutTitles[lang] || aboutTitles.en}</h3>
      <p>{aboutDescs[lang] || aboutDescs.en}</p>
      
    </div>
  </div>
</DemoLayout>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(20,184,166,0.15), rgba(34,197,94,0.1));
    border: 1px solid rgba(20,184,166,0.25);
    color: #14b8a6;
    margin-bottom: 1rem;
  }
  .demo-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, #14b8a6, #22c55e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  .demo-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }
  .demo-lead strong { color: var(--text-primary, #e4e4e7); }

  .demo-info {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .demo-info h3 {
    margin-bottom: 0.75rem;
  }

  .demo-info p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

    </style>
