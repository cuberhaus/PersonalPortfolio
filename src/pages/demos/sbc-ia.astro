---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import SbcDemo from '../../components/demos/SbcDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('sbc-ia', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="sbc-ia"
  ogImage="/og/sbc-ia-og.png"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl={demo.github}
      githubLabel={t('demo.viewSource')}
      accent={demo.accent}
    />

    <LiveAppEmbed
      slug="sbc-ia"
      title="SBC_IA Trip Planner"
      lang={lang}
      fallbackSelector="#sbc-mock-fallback"
      client:load
    />

    <div id="sbc-mock-fallback" class="sbc-demo-wrapper">
      <SbcDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>

<style>
  .sbc-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }
</style>
