---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import LiveAppEmbed from '../../components/demos/LiveAppEmbed';
import SbcDemo from '../../components/demos/SbcDemo';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getDemo } from '../../i18n/demo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demo = getDemo('sbc-ia', lang);
---

<DemoLayout
  title={demo.title}
  description={demo.metaDescription}
  slug="sbc-ia"
>
  <div class="container">
    <DemoHeader
      badge={demo.badge}
      title={demo.title}
      lead={demo.lead}
      githubUrl="https://github.com/cuberhaus/SBC_IA"
      githubLabel={t('demo.viewSource')}
      accentFrom="#6366f1"
      accentTo="#22c55e"
    />

    <LiveAppEmbed
      url="http://localhost:8088"
      title="SBC_IA Trip Planner"
      dockerCmd="cd SBC_IA && docker compose up -d"
      devCmd="cd SBC_IA && make web-dev"
      lang={lang}
      fallbackSelector="#sbc-mock-fallback"
      client:load
    />

    <div id="sbc-mock-fallback" class="sbc-demo-wrapper">
      <SbcDemo lang={lang} client:visible />
    </div>
  </div>
</DemoLayout>

<style>
  .sbc-demo-wrapper {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
    background: var(--bg-card);
    padding: 1.5rem;
    min-height: 400px;
  }
</style>
