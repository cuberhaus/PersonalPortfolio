---
/**
 * Localized demo router.
 *
 * Adding a new demo? Drop a new file at `src/pages/demos/<slug>.astro` and
 * the corresponding entry in `src/data/demos.json` (+ .es.json / .ca.json).
 * `import.meta.glob` picks the page up automatically — no edits needed here.
 */
import { LOCALES } from '../../../config/locales';

const demoModules = import.meta.glob('../../demos/*.astro', { eager: true }) as
  Record<string, { default: unknown }>;

const demosBySlug = Object.fromEntries(
  Object.entries(demoModules).map(([path, mod]) => {
    const slug = path.match(/\/([^/]+)\.astro$/)![1];
    return [slug, mod.default];
  })
);

export function getStaticPaths() {
  const localeModules = import.meta.glob('../../demos/*.astro', { eager: true });
  const slugs = Object.keys(localeModules).map(
    p => p.match(/\/([^/]+)\.astro$/)![1]
  );
  // Default locale is served from /demos/<slug>; this dynamic route only
  // exists for the prefixed locales (es, ca, …).
  const langs = LOCALES.filter(l => l !== 'en');
  return langs.flatMap(lang => slugs.map(demo => ({ params: { lang, demo } })));
}

const { demo } = Astro.params;
const Component = demosBySlug[demo as string] as
  | ((props: Record<string, unknown>) => unknown)
  | undefined;
---

{Component && <Component />}
