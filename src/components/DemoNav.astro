---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { renderIconSvg } from '../lib/demo-icons';
import demosEn from '../data/demos.json';
import demosEs from '../data/demos.es.json';
import demosCa from '../data/demos.ca.json';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const allDemos = lang === 'es' ? demosEs : lang === 'ca' ? demosCa : demosEn;
const demos = allDemos.filter(d => d.slug !== currentSlug);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

function demoHref(slug: string) {
  return lang === 'en' ? `${base}/demos/${slug}/` : `${base}/${lang}/demos/${slug}/`;
}
---

<section class="demo-nav-section">
  <div class="container">
    <h2 class="demo-nav-heading">{t('demo.moreProjects')}</h2>
    <div class="demo-nav-grid">
      {demos.map((demo) => (
        <a href={demoHref(demo.slug)} class="demo-nav-card" data-astro-reload>
          <span class="demo-nav-icon" set:html={renderIconSvg(demo.icon, 20)} />
          <div class="demo-nav-info">
            <span class="demo-nav-title">{demo.title}</span>
            <ul class="demo-nav-tags">
              {demo.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
          <svg class="demo-nav-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .demo-nav-section {
    margin-top: 4rem;
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--border-color);
  }

  .demo-nav-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .demo-nav-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .demo-nav-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .demo-nav-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent-start);
    box-shadow: 0 6px 24px var(--glow-color);
  }

  .demo-nav-icon {
    flex-shrink: 0;
    color: var(--accent-start);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .demo-nav-info {
    flex: 1;
    min-width: 0;
  }

  .demo-nav-title {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .demo-nav-card:hover .demo-nav-title {
    color: var(--accent-start);
  }

  .demo-nav-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.3rem;
  }

  .demo-nav-tags li {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
  }

  .demo-nav-arrow {
    flex-shrink: 0;
    color: var(--text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast), color var(--transition-fast);
  }

  .demo-nav-card:hover .demo-nav-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent-start);
  }

  @media (max-width: 768px) {
    .demo-nav-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
