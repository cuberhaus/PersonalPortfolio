---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import projectsData from '../data/work_projects.json';
import { flattenForLocale } from '../i18n/load';
import { renderIconSvg } from '../lib/demo-icons';

type WorkEntry = {
  title: string;
  company: string;
  role: string;
  description: string;
  tags: string[];
  icon: string;
  link?: string;
  fallback?: string;
};

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = flattenForLocale<WorkEntry>(projectsData as never, lang);

const { num } = Astro.props;
---

<section class="section work-projects" id="work" data-num={num}>
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('work.label')}</span>
      <h2 class="section-title">{t('work.title')}</h2>
      <p class="section-subtitle">
        {t('work.subtitle')}
      </p>
    </div>

    <div class="work-grid reveal-stagger">
      {
        projects.map((project) => (
          <div class="work-card">
            {project.link ? (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="work-card-inner work-card-link"
                {...(project.fallback ? { 'data-fallback': project.fallback } : {})}
              >
                <div class="work-icon" set:html={renderIconSvg(project.icon, 28)} />

                <div class="work-badge">
                  <span>{project.company}</span>
                </div>

                <h3 class="work-title">{project.title}</h3>
                <p class="work-role">{project.role}</p>
                <p class="work-desc">{project.description}</p>

                <ul class="work-tags">
                  {project.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </a>
            ) : (
              <div class="work-card-inner">
                <div class="work-icon" set:html={renderIconSvg(project.icon, 28)} />

                <div class="work-badge">
                  <span>{project.company}</span>
                </div>

                <h3 class="work-title">{project.title}</h3>
                <p class="work-role">{project.role}</p>
                <p class="work-desc">{project.description}</p>

                <ul class="work-tags">
                  {project.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .work-card {
    position: relative;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
    overflow: hidden;
    display: flex;
  }

  .work-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .work-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-text);
    box-shadow: 0 12px 40px var(--glow-color);
  }

  .work-card:hover::before {
    opacity: 1;
  }

  .work-card-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }

  .work-card-link {
    color: inherit;
    text-decoration: none;
  }

  .work-icon {
    color: var(--accent-text);
    margin-bottom: 1.25rem;
  }

  .work-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-primary);
    background: var(--bg-secondary);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    opacity: 0.8;
  }

  .work-title {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }

  .work-role {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--accent-text);
    margin-bottom: 1rem;
  }

  .work-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .work-tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 1024px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document
    .querySelectorAll<HTMLAnchorElement>('a.work-card-link[data-fallback]')
    .forEach((link) => {
      link.addEventListener('click', async (e) => {
        const fallback = link.dataset.fallback;
        if (!fallback) return;
        try {
          await fetch(link.href, { method: 'HEAD', mode: 'no-cors' });
        } catch {
          e.preventDefault();
          window.open(fallback, '_blank', 'noopener,noreferrer');
        }
      });
    });
</script>
