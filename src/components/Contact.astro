---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// To activate the contact form, replace this with your actual Web3Forms access key
// You can get one for free at https://web3forms.com/
const web3FormsKey = "ca12b98d-ade0-4844-b3a5-24bbd4197c8a";
---

<section class="section contact" id="contact" data-num="07">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('contact.label')}</span>
      <h2 class="section-title">{t('contact.title')}</h2>
    </div>

    <div class="contact-content reveal">
      <p class="contact-text">{t('contact.text')}</p>
      
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="contact-form"
        id="contact-form"
        data-success-msg={t('contact.success')}
        data-error-msg={t('contact.error')}
        data-invalid-email-msg={t('contact.invalidEmail')}
        data-send-msg={t('contact.cta')}
        data-sending-msg={t('contact.sending')}
        data-did-you-mean-msg={t('contact.didYouMean')}
        data-use-suggestion-msg={t('contact.useSuggestion')}
      >
        <input type="hidden" name="access_key" value={web3FormsKey} />

        <div class="form-group">
          <label for="name">{t('contact.name')}</label>
          <input type="text" id="name" name="name" required placeholder={t('contact.namePlaceholder')} />
        </div>

        <div class="form-group">
          <label for="email">{t('contact.email')}</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            spellcheck="false"
            autocapitalize="none"
            placeholder={t('contact.emailPlaceholder')}
          />
          <p id="email-hint" class="email-hint" role="status" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="message">{t('contact.message')}</label>
          <textarea id="message" name="message" rows="5" required placeholder={t('contact.messagePlaceholder')}></textarea>
        </div>

        <!-- Honeypot Spam Protection -->
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

        <button type="submit" class="contact-submit" id="submit-btn">
          <span>{t('contact.cta')}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
        <p id="form-result" class="form-result" role="status" aria-live="polite"></p>
      </form>
    </div>

    <div class="contact-socials reveal">
      <a href="https://github.com/cuberhaus" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href="https://linkedin.com/in/polcasacubertagil" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="mailto:polcg10@gmail.com" aria-label="Email">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M22 4L12 13 2 4"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { validateEmail } from '../lib/email-validator';

  type Msgs = {
    success: string;
    error: string;
    invalidEmail: string;
    send: string;
    sending: string;
    didYouMean: string;
    useSuggestion: string;
  };

  const readMsgs = (form: HTMLFormElement): Msgs => ({
    success: form.dataset.successMsg ?? 'Thanks! Your message has been sent.',
    error: form.dataset.errorMsg ?? 'Oops! Something went wrong.',
    invalidEmail: form.dataset.invalidEmailMsg ?? 'Please enter a valid email address.',
    send: form.dataset.sendMsg ?? 'Send Message',
    sending: form.dataset.sendingMsg ?? 'Sending...',
    didYouMean: form.dataset.didYouMeanMsg ?? 'Did you mean',
    useSuggestion: form.dataset.useSuggestionMsg ?? 'Use this',
  });

  const clearHint = (hint: HTMLElement) => {
    hint.textContent = '';
    hint.classList.remove('error', 'suggestion');
    hint.style.display = 'none';
  };

  const showError = (hint: HTMLElement, text: string) => {
    hint.textContent = text;
    hint.classList.remove('suggestion');
    hint.classList.add('error');
    hint.style.display = 'block';
  };

  const showSuggestion = (
    hint: HTMLElement,
    input: HTMLInputElement,
    msgs: Msgs,
    suggestion: string,
  ) => {
    hint.replaceChildren();
    hint.classList.remove('error');
    hint.classList.add('suggestion');
    hint.style.display = 'block';

    hint.append(document.createTextNode(`${msgs.didYouMean} `));
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'email-suggest-btn';
    btn.textContent = suggestion;
    btn.setAttribute('aria-label', `${msgs.useSuggestion}: ${suggestion}`);
    btn.addEventListener('click', () => {
      input.value = suggestion;
      input.dispatchEvent(new Event('input', { bubbles: true }));
      clearHint(hint);
      input.focus();
    });
    hint.append(btn, document.createTextNode('?'));
  };

  const initForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form || form.dataset.initialized === 'true') return;
    form.dataset.initialized = 'true';

    const result = document.getElementById('form-result') as HTMLElement | null;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const btnText = btn?.querySelector('span') ?? null;
    const emailInput = form.querySelector('#email') as HTMLInputElement | null;
    const emailHint = document.getElementById('email-hint') as HTMLElement | null;

    const msgs = readMsgs(form);

    // Live validation on blur / input so the user gets immediate feedback
    // without having to hit Send first.
    if (emailInput && emailHint) {
      emailInput.addEventListener('blur', () => {
        const raw = emailInput.value;
        if (!raw.trim()) {
          clearHint(emailHint);
          return;
        }
        const res = validateEmail(raw);
        if (res.valid) {
          clearHint(emailHint);
        } else if (res.reason === 'typo') {
          showSuggestion(emailHint, emailInput, msgs, res.suggestion);
        } else if (res.reason === 'format') {
          showError(emailHint, msgs.invalidEmail);
        } else {
          clearHint(emailHint);
        }
      });

      // Clear the hint as soon as the user edits again — avoids stale
      // suggestions hanging around while they fix the address.
      emailInput.addEventListener('input', () => clearHint(emailHint));
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const emailValue = emailInput?.value ?? '';
      const res = validateEmail(emailValue);

      if (!res.valid) {
        if (emailHint && emailInput) {
          if (res.reason === 'typo') {
            showSuggestion(emailHint, emailInput, msgs, res.suggestion);
          } else {
            showError(emailHint, msgs.invalidEmail);
          }
        }
        if (result) {
          result.textContent = msgs.invalidEmail;
          result.classList.remove('success');
          result.classList.add('error');
          result.style.display = 'block';
        }
        emailInput?.focus();
        return;
      }

      const formData = new FormData(form);
      formData.set('email', res.normalized);
      const payload = JSON.stringify(Object.fromEntries(formData));

      if (result) result.style.display = 'none';
      if (btnText) btnText.textContent = msgs.sending;
      if (btn) {
        btn.style.opacity = '0.7';
        btn.style.pointerEvents = 'none';
      }

      type DebugApi = { log: (lvl: string, ns: string, msg: string, ...args: unknown[]) => void };
      const dbg = (window as unknown as { __debug?: DebugApi }).__debug;
      dbg?.log('info', 'net:contact', 'submit');
      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: payload,
      })
        .then(async (response) => {
          const body = await response.json().catch(() => ({} as Record<string, unknown>));
          if (!result) return;
          if (response.ok) {
            result.textContent = msgs.success;
            result.classList.remove('error');
            result.classList.add('success');
            result.style.display = 'block';
            form.reset();
            if (emailHint) clearHint(emailHint);
            dbg?.log('info', 'net:contact', 'submit-ok', { id: (body as Record<string, unknown>).id ?? null });
          } else {
            result.textContent = msgs.error;
            result.classList.remove('success');
            result.classList.add('error');
            result.style.display = 'block';
            dbg?.log('error', 'net:contact', 'submit-failed', { status: response.status, body });
          }
        })
        .catch((err) => {
          if (!result) return;
          result.textContent = msgs.error;
          result.classList.remove('success');
          result.classList.add('error');
          result.style.display = 'block';
          dbg?.log('error', 'net:contact', 'submit-failed', { err: String(err) });
        })
        .finally(() => {
          if (btnText) btnText.textContent = msgs.send;
          if (btn) {
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'all';
          }
          setTimeout(() => {
            if (result) result.style.display = 'none';
          }, 5000);
        });
    });
  };

  initForm();
  document.addEventListener('astro:page-load', initForm);
</script>

<style>
  .contact {
    padding-bottom: 6rem;
  }

  .contact-content {
    max-width: 600px;
    margin: 0 auto;
    margin-top: 3rem;
  }

  .contact-text {
    text-align: center;
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--bg-secondary);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 1rem;
    transition: all var(--transition-base);
  }

  .form-group textarea {
    resize: none;
    min-height: 140px;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-start);
    box-shadow: 0 0 0 2px var(--glow-color);
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    color: #fff;
    background: var(--accent-gradient);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    margin-top: 1rem;
  }

  .contact-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--glow-color-strong);
  }

  .contact-submit svg {
    transition: transform var(--transition-fast);
  }

  .contact-submit:hover svg {
    transform: translate(2px, -2px);
  }

  .form-result {
    display: none;
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .form-result.success {
    color: #10b981;
  }

  .form-result.error {
    color: #ef4444;
  }

  .email-hint {
    display: none;
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  .email-hint.error {
    color: #ef4444;
  }

  .email-hint.suggestion {
    color: var(--text-secondary);
  }

  .email-suggest-btn {
    display: inline;
    padding: 0;
    margin: 0 0.15rem;
    background: none;
    border: none;
    color: var(--accent-start);
    font: inherit;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }

  .email-suggest-btn:hover,
  .email-suggest-btn:focus-visible {
    color: var(--accent-end);
    outline: none;
  }

  .contact-socials {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .contact-socials a {
    color: var(--text-muted);
    transition: color var(--transition-fast), transform var(--transition-fast), filter var(--transition-fast);
  }

  .contact-socials a:hover {
    color: var(--accent-start);
    transform: translateY(-3px);
    filter: drop-shadow(0 0 8px var(--glow-color));
  }

  @media (max-width: 768px) {
    .contact-form {
      padding: 1.5rem;
    }
  }
</style>