---
/**
 * Debug system entry point — head-only, script-only.
 *
 * Inserted into `<head>` of both `Layout.astro` and `DemoLayout.astro` next to
 * `<ThemeInit position="head" />`. Mirrors the same enable-detection pattern
 * (URL param + localStorage) already used by ThemeInit, so behaviour is
 * consistent across the site.
 *
 * The React overlay itself is mounted by `<DebugMount />` at the end of
 * `<body>` because rendering visible elements inside `<head>` is invalid
 * HTML and triggers inconsistent browser auto-correction.
 *
 * Activation rules (apply in dev and prod identically — overlay is opt-in):
 *   - `?debug=1`                          → enables, persists to localStorage
 *   - `?debug=0`                          → disables, clears localStorage
 *   - `localStorage.debug='1'`            → enables on every page load
 *   - `Alt+Shift+D`                       → toggles enabled flag (Ctrl+Shift+D
 *                                          is reserved by browsers for
 *                                          "Bookmark All Tabs")
 *   - otherwise                           → bus is silent except for errors
 *
 * The inline script below pre-installs error listeners *before* any other
 * module loads, so unhandled rejections during early page parse are captured.
 */
---

<script is:inline>
  (function () {
    var url = new URL(window.location.href);
    var param = url.searchParams.get('debug');
    if (param === '1') {
      try { localStorage.setItem('debug', '1'); } catch (_) { /* private mode */ }
      url.searchParams.delete('debug');
      history.replaceState(null, '', url.pathname + url.search + url.hash);
    } else if (param === '0') {
      try { localStorage.removeItem('debug'); } catch (_) { /* private mode */ }
      url.searchParams.delete('debug');
      history.replaceState(null, '', url.pathname + url.search + url.hash);
    }

    var stored = false;
    try { stored = localStorage.getItem('debug') === '1'; } catch (_) { /* private mode */ }
    window.__DEBUG_ENABLED = stored;

    var pending = [];
    window.addEventListener('error', function (e) {
      pending.push({ level: 'error', ns: 'global', msg: e.message || 'Uncaught error', err: e.error });
    });
    window.addEventListener('unhandledrejection', function (e) {
      pending.push({ level: 'error', ns: 'global', msg: 'Unhandled promise rejection', err: e.reason });
    });
    window.__debugPendingErrors = pending;

    // Toggle debug overlay. Multiple combos for redundancy because:
    //   - Ctrl+Shift+D is browser-bound to "Bookmark All Tabs"
    //   - Alt+Shift is GNOME's default keyboard-layout switcher on Linux
    //   - Ctrl+Alt+D is GNOME's default "Show Desktop"
    // `Ctrl+Alt+Shift+D` (4 modifiers) and `Ctrl+\`` (backtick) are unbound
    // on every common OS/browser combo we have data for.
    // Uses `e.code` (physical key) rather than `e.key` (layout-dependent
    // glyph) so Linux/intl keyboards still work.
    function toggleDebug() {
      var nowEnabled = !window.__DEBUG_ENABLED;
      window.__DEBUG_ENABLED = nowEnabled;
      try {
        if (nowEnabled) localStorage.setItem('debug', '1');
        else localStorage.removeItem('debug');
      } catch (_) { /* private mode */ }
      document.dispatchEvent(new CustomEvent('debug:toggle', { detail: { enabled: nowEnabled } }));
      // Mirror through the bus so the entry shows up in the overlay log too.
      // `window.__debug` may not be installed yet on the very first toggle
      // (the overlay lazy-loads it), so guard.
      if (window.__debug) {
        window.__debug.log('info', 'debug', 'toggle', { enabled: nowEnabled });
      }
    }
    document.addEventListener('keydown', function (e) {
      var isCombo =
        // Ctrl+Alt+Shift+D — primary, no known OS/browser conflicts
        (e.code === 'KeyD' && e.ctrlKey && e.altKey && e.shiftKey) ||
        // Ctrl+Backtick — reliable single-modifier fallback
        (e.code === 'Backquote' && e.ctrlKey && !e.altKey && !e.shiftKey) ||
        // Alt+Shift+D — kept for convenience where the OS doesn't eat it
        (e.code === 'KeyD' && e.altKey && e.shiftKey && !e.ctrlKey);
      if (isCombo) {
        e.preventDefault();
        toggleDebug();
      }
    });
    // Expose for manual triggering from the devtools console as a final fallback.
    window.__toggleDebug = toggleDebug;
  })();
</script>
