---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// We calculate the path dynamically so it evaluates correctly at build time
const hasProfileImage = existsSync(resolve('./public/profile.jpg'));

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section about" id="about">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('about.label')}</span>
      <h2 class="section-title">{t('about.title')}</h2>
    </div>

    <div class={`about-grid reveal ${hasProfileImage ? '' : 'no-image'}`}>
      <div class="about-text">
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
        <ul class="about-tech-list">
          <li>Python</li>
          <li>SQL & PowerBI</li>
          <li>AWS & Azure</li>
          <li>Machine Learning</li>
          <li>Informatica</li>
          <li>Computer Vision</li>
        </ul>
      </div>

      {hasProfileImage && (
        <div class="about-image-wrapper">
          <div class="about-image-placeholder">
            <img
              src={import.meta.env.BASE_URL === '/' ? '/profile.jpg' : `${import.meta.env.BASE_URL}/profile.jpg`}
              alt="Pol Casacuberta"
              width="300"
              height="300"
              loading="lazy"
            />
          </div>
          <div class="about-image-border" aria-hidden="true"></div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    margin-bottom: 1rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .about-tech-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1rem;
    margin-top: 1rem;
  }

  .about-tech-list li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    position: relative;
    padding-left: 1.25rem;
  }

  .about-tech-list li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent-start);
    font-size: 0.9rem;
  }

  .about-image-wrapper {
    position: relative;
    max-width: 300px;
    justify-self: center;
  }

  .about-image-placeholder {
    position: relative;
    z-index: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .about-image-placeholder img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    filter: grayscale(20%);
    transition: filter var(--transition-base);
  }

  .about-image-wrapper:hover .about-image-placeholder img {
    filter: grayscale(0%);
  }

  .about-image-border {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 100%;
    height: 100%;
    border: 2px solid var(--accent-start);
    border-radius: var(--radius-lg);
    opacity: 0.3;
    transition: transform var(--transition-base);
  }

  .about-image-wrapper:hover .about-image-border {
    transform: translate(-4px, -4px);
  }

  .about-grid.no-image {
    grid-template-columns: 1fr;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-image-wrapper {
      max-width: 250px;
    }
  }
</style>
