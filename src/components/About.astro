---
import { createHash } from 'node:crypto';
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Pick the PDF for the current locale; fall back to English if the localized
// PDF hasn't been fetched for this build.
const cvByLang: Record<string, string> = {
  en: 'cv.pdf',
  es: 'cv_es.pdf',
  ca: 'cv_ca.pdf',
};
const cvFile = existsSync(resolve(`./public/${cvByLang[lang]}`))
  ? cvByLang[lang]
  : (existsSync(resolve('./public/cv.pdf')) ? 'cv.pdf' : null);

// Hash the PDF bytes so the URL changes whenever the file changes,
// busting both browser and CDN caches without manual purges.
const cvHash = cvFile
  ? createHash('sha1').update(readFileSync(resolve(`./public/${cvFile}`))).digest('hex').slice(0, 8)
  : '';

// We calculate the path dynamically so it evaluates correctly at build time
const hasProfileImage = existsSync(resolve('./public/profile.jpg'));
const hasCV = cvFile !== null;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const cvHref = cvFile ? `${base}/${cvFile}?v=${cvHash}` : '#';
---

<section class="section about" id="about" data-num="01">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('about.label')}</span>
      <h2 class="section-title">{t('about.title')}</h2>
    </div>

    <div class={`about-grid reveal ${hasProfileImage ? '' : 'no-image'}`}>
      <div class="about-text">
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
        <ul class="about-tech-list">
          <li>Python</li>
          <li>SQL & Power BI</li>
          <li>AWS & Azure</li>
          <li>Machine Learning</li>
          <li>Generative AI</li>
          <li>Computer Vision</li>
        </ul>
        
        {hasCV && (
          <div class="about-actions">
            <a href={cvHref} class="about-cv-btn" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              {t('about.cv')}
            </a>
          </div>
        )}
      </div>

      {hasProfileImage && (
        <div class="about-image-wrapper">
          <div class="about-image-placeholder">
            <img
              src={import.meta.env.BASE_URL === '/' ? '/profile.jpg' : `${import.meta.env.BASE_URL}/profile.jpg`}
              alt="Pol Casacuberta"
              width="300"
              height="300"
              loading="lazy"
            />
          </div>
          <div class="about-image-border" aria-hidden="true"></div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    margin-bottom: 1rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .about-tech-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1rem;
    margin-top: 1rem;
  }

  .about-tech-list li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    position: relative;
    padding-left: 1.25rem;
  }

  .about-tech-list li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent-start);
    font-size: 0.9rem;
  }

  .about-actions {
    margin-top: 2rem;
  }
  
  .about-cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .about-cv-btn:hover {
    border-color: var(--accent-start);
    color: var(--accent-start);
    background: rgba(99, 102, 241, 0.05);
  }

  .about-image-wrapper {
    position: relative;
    max-width: 300px;
    justify-self: center;
  }

  .about-image-placeholder {
    position: relative;
    z-index: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .about-image-placeholder img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    filter: grayscale(20%);
    transition: filter var(--transition-base);
  }

  .about-image-wrapper:hover .about-image-placeholder img {
    filter: grayscale(0%);
  }

  .about-image-border {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 100%;
    height: 100%;
    border: 2px solid var(--accent-start);
    border-radius: var(--radius-lg);
    opacity: 0.3;
    transition: transform var(--transition-base);
  }

  .about-image-wrapper:hover .about-image-border {
    transform: translate(-4px, -4px);
  }

  .about-grid.no-image {
    grid-template-columns: 1fr;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-image-wrapper {
      max-width: 250px;
    }
  }
</style>
