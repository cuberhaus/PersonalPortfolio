---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { renderIssuerIconSvg } from '../lib/issuer-icons';
import { certifications as certsData, getTranslations } from '../data/loaders';
import { visibleEntries } from '../data/visibility';
import { flattenForLocale } from '../i18n/load';

type CertEntry = {
  name: string;
  issuer: string;
  issuerIcon: string;
  issued: string;
  link?: string;
  fallback?: string;
  badgeImage?: string;
  badgeImageFallback?: string;
  hidden?: boolean;
};

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const certs = visibleEntries(
  flattenForLocale<CertEntry>(certsData as never, lang, getTranslations('certifications', lang))
);

const { num } = Astro.props;
---

<section class="section certifications" id="certifications" data-num={num}>
  <div class={`container${certs.length > 6 ? ' has-desktop-extra' : ''}`}>
    <div class="reveal">
      <span class="section-label">{t('certifications.label')}</span>
      <h2 class="section-title">{t('certifications.title')}</h2>
      <p class="section-subtitle">{t('certifications.subtitle')}</p>
    </div>

    <div class="cert-filters reveal" role="group" aria-label="Filter certifications by issuer">
      <button class="cert-filter-btn active" data-issuer="all" aria-pressed="true">
        {t('certifications.all')}
      </button>
      {
        Array.from(new Set(certs.map((c) => c.issuer))).map((issuer) => (
          <button class="cert-filter-btn" data-issuer={issuer} aria-pressed="false">
            {issuer}
          </button>
        ))
      }
    </div>
    <div aria-live="polite" class="sr-only" id="cert-filter-announcer"></div>

    <ul class="certifications-grid reveal-stagger" id="certifications-grid" data-mobile-limit="3">
      {
        certs.map((c, i) => {
          const Inner = (
            <>
              <div
                class="certification-icon"
                aria-hidden="true"
                set:html={renderIssuerIconSvg(c.issuerIcon, 24)}
              />
              {c.issued && <span class="certification-period">{c.issued}</span>}
              <h3 class="certification-name">{c.name}</h3>
              <p class="certification-issuer">{c.issuer}</p>
              {c.link && (
                <p class="certification-credential">
                  {t('certifications.viewCredential')} <span aria-hidden="true">↗</span>
                </p>
              )}
              {c.badgeImage && (
                <div class="certification-badge-popover" aria-hidden="true">
                  <img
                    src={c.badgeImage}
                    alt=""
                    width="160"
                    height="160"
                    loading="lazy"
                    data-fallback={c.badgeImageFallback}
                    onerror="const fb=this.dataset.fallback;if(fb&&this.src!==fb){this.src=fb}else{this.parentElement.style.display='none'}"
                  />
                </div>
              )}
            </>
          );
          return (
            <li
              class={`certification-card ${i >= 6 ? 'hidden-demo extra-demo' : ''}${i >= 3 && i < 6 ? ' mobile-extra-demo mobile-hidden-demo' : ''}`}
              data-issuer={c.issuer}
            >
              {c.link ? (
                <a
                  href={c.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="certification-link"
                  aria-label={`${c.name} — ${c.issuer}`}
                  {...(c.fallback ? { 'data-fallback': c.fallback } : {})}
                >
                  {Inner}
                </a>
              ) : (
                <div class="certification-link">{Inner}</div>
              )}
            </li>
          );
        })
      }
    </ul>

    {
      certs.length > 3 && (
        <button
          class="certifications-toggle"
          id="certifications-toggle"
          data-show-more={t('certifications.showMore')}
          data-show-less={t('certifications.showLess')}
        >
          {t('certifications.showMore')}
        </button>
      )
    }
  </div>
</section>

<style>
  .cert-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .cert-filter-btn {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }

  .cert-filter-btn:hover {
    border-color: var(--accent-text);
    color: var(--text-primary);
  }

  .cert-filter-btn.active {
    background: color-mix(in srgb, var(--accent-start) 15%, transparent);
    border-color: var(--accent-text);
    color: var(--accent-text);
  }

  .certifications-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
  }

  .certification-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .certification-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .certification-card:hover {
    border-color: var(--accent-text);
    box-shadow: 0 12px 40px var(--glow-color);
  }

  .certification-card:hover::before {
    opacity: 1;
  }

  .certification-link {
    display: block;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .certification-icon {
    color: var(--accent-text);
    margin-bottom: 1.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    min-width: 24px;
    min-height: 24px;
  }

  .certification-icon :global(svg) {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }

  .certification-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-text);
    display: block;
    margin-bottom: 0.5rem;
  }

  .certification-name {
    font-size: 1.05rem;
    line-height: 1.35;
    margin-bottom: 0.5rem;
  }

  .certification-issuer {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .certification-credential {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .certification-link:hover .certification-credential,
  .certification-link:focus-visible .certification-credential {
    color: var(--accent-text);
  }

  /* Badge image popover on hover */
  .certification-badge-popover {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    max-width: 120px;
    max-height: 80px;
    opacity: 0;
    transform: scale(0.8) translateY(4px);
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    z-index: 2;
  }

  .certification-badge-popover img {
    max-width: 100%;
    max-height: 80px;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg);
  }

  .certification-card:hover .certification-badge-popover {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  @media (max-width: 768px) {
    .certification-badge-popover {
      opacity: 1;
      transform: scale(1) translateY(0);
      max-width: 60px;
      max-height: 60px;
    }

    .certification-badge-popover img {
      max-height: 60px;
    }
  }

  /* Desktop: hide items beyond 6 */
  /* (Handled by JS now) */

  @media (max-width: 768px) {
    .certifications-grid {
      grid-template-columns: 1fr;
    }
  }

  .certifications-toggle {
    display: none;
    margin: 1.5rem auto 0;
    padding: 0.6rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--accent-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .certifications-toggle:hover {
    border-color: var(--accent-text);
    box-shadow: 0 4px 20px var(--glow-color);
  }

  /* Show button on desktop when there are >6 items */
  .has-desktop-extra .certifications-toggle {
    display: block;
  }

  /* Show button on mobile always (rendered only when >3 items) */
  @media (max-width: 768px) {
    .certifications-toggle {
      display: block;
    }
  }

  /* ── Filter / Pagination Animation Classes ── */
  @media (max-width: 640px) {
    .mobile-hidden-demo {
      display: none !important;
    }

    .mobile-extra-demo {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
        transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
      transition-delay: 0ms !important;
    }

    .mobile-extra-demo.visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hidden-demo {
    display: none !important;
  }

  .extra-demo {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
    transition-delay: 0ms !important;
  }

  .extra-demo.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('certifications-toggle');
    const grid = document.getElementById('certifications-grid');
    const filterBtns = document.querySelectorAll('.cert-filter-btn');
    const announcer = document.getElementById('cert-filter-announcer');

    if (!grid) return;

    let currentIssuer = 'all';
    const isMobile = () => window.matchMedia('(max-width: 768px)').matches;
    const getAllCards = () => [...grid.querySelectorAll('.certification-card')];
    const getVisibleCards = () => {
      if (currentIssuer === 'all') return getAllCards();
      return getAllCards().filter((c) => c.getAttribute('data-issuer') === currentIssuer);
    };

    let mobileShown = 3;

    function updateGrid() {
      const cards = getAllCards();
      const visibleCards = getVisibleCards();
      const totalCount = visibleCards.length;

      if (announcer) {
        announcer.textContent = `Showing ${totalCount} certifications`;
      }

      // Hide all cards first
      cards.forEach((card) => {
        card.classList.remove('visible');
        card.classList.add('hidden-demo');
        card.classList.remove('mobile-hidden-demo', 'mobile-extra-demo', 'extra-demo');
      });

      if (isMobile()) {
        const end = Math.min(mobileShown, totalCount);
        for (let i = 0; i < end; i++) {
          visibleCards[i].classList.remove('hidden-demo');
          visibleCards[i].classList.add('visible');
        }

        if (btn) {
          if (mobileShown >= totalCount) {
            btn.textContent = btn.getAttribute('data-show-less');
            btn.setAttribute('aria-expanded', 'true');
            btn.classList.add('expanded');
            if (totalCount <= 3) btn.style.display = 'none';
            else btn.style.display = 'block';
          } else {
            btn.textContent = btn.getAttribute('data-show-more');
            btn.setAttribute('aria-expanded', 'false');
            btn.classList.remove('expanded');
            btn.style.display = 'block';
          }
        }
      } else {
        const isExpanded = btn?.classList.contains('expanded');
        const limit = isExpanded ? totalCount : Math.min(6, totalCount);

        for (let i = 0; i < limit; i++) {
          visibleCards[i].classList.remove('hidden-demo');
          visibleCards[i].classList.add('visible');
        }

        if (btn) {
          if (totalCount <= 6) {
            btn.style.display = 'none';
          } else {
            btn.style.display = 'block';
            btn.textContent = isExpanded
              ? btn.getAttribute('data-show-less')
              : btn.getAttribute('data-show-more');
            btn.setAttribute('aria-expanded', String(isExpanded));
          }
        }
      }
    }

    filterBtns.forEach((fBtn) => {
      fBtn.addEventListener('click', () => {
        const issuer = fBtn.getAttribute('data-issuer') || 'all';
        if (issuer === currentIssuer) return;

        currentIssuer = issuer;
        mobileShown = 3;
        if (btn) {
          btn.classList.remove('expanded');
          btn.setAttribute('aria-expanded', 'false');
          btn.textContent = btn.getAttribute('data-show-more');
        }

        filterBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        fBtn.classList.add('active');
        fBtn.setAttribute('aria-pressed', 'true');

        updateGrid();
      });
    });

    function scrollToCerts() {
      const section = document.getElementById('certifications');
      if (section) {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        section.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth' });
      }
    }

    if (btn) {
      btn.addEventListener('click', () => {
        const visibleCards = getVisibleCards();
        const totalCount = visibleCards.length;

        if (isMobile()) {
          if (mobileShown >= totalCount) {
            mobileShown = 3;
            updateGrid();
            scrollToCerts();
          } else {
            const start = mobileShown;
            mobileShown = Math.min(mobileShown + 3, totalCount);

            let stagger = 0;
            for (let i = start; i < mobileShown; i++) {
              const card = visibleCards[i];
              card.classList.remove('hidden-demo');
              const delay = 20 + stagger * 60;
              setTimeout(() => card.classList.add('visible'), delay);
              stagger++;
            }

            if (mobileShown >= totalCount) {
              btn.textContent = btn.getAttribute('data-show-less');
              btn.setAttribute('aria-expanded', 'true');
              btn.classList.add('expanded');
            }
          }
        } else {
          const isExpanded = btn.classList.toggle('expanded');
          btn.setAttribute('aria-expanded', String(isExpanded));

          if (isExpanded) {
            for (let i = 6; i < totalCount; i++) {
              const card = visibleCards[i];
              card.classList.remove('hidden-demo');
              setTimeout(() => card.classList.add('visible'), 20 + (i - 6) * 60);
            }
          } else {
            for (let i = 6; i < totalCount; i++) {
              const card = visibleCards[i];
              card.classList.remove('visible');
              setTimeout(() => card.classList.add('hidden-demo'), 400);
            }
            scrollToCerts();
          }

          btn.textContent = isExpanded
            ? btn.getAttribute('data-show-less')
            : btn.getAttribute('data-show-more');
        }
      });
    }

    // Initial setup
    updateGrid();
  });

  // Fallback: if the external cert link is unreachable, swap to the local copy
  document
    .querySelectorAll<HTMLAnchorElement>('a.certification-link[data-fallback]')
    .forEach((link) => {
      link.addEventListener('click', async (e) => {
        const fallback = link.dataset.fallback;
        if (!fallback) return;
        try {
          const res = await fetch(link.href, { method: 'HEAD', mode: 'no-cors' });
        } catch {
          e.preventDefault();
          window.open(fallback, '_blank', 'noopener,noreferrer');
        }
      });
    });
</script>
