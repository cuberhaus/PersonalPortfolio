---
import { THEMES, THEME_IDS } from '../lib/themes';
import { DESIGNS, DESIGN_IDS, DEFAULT_DESIGN } from '../lib/designs';

interface Props {
  position: 'head' | 'body';
}

const { position } = Astro.props;
const darkThemes = THEMES.filter(t => t.colorScheme === 'dark' && !t.hidden);
const lightThemes = THEMES.filter(t => t.colorScheme === 'light' && !t.hidden);

/**
 * Reverse map: paletteId -> design ids that list this palette in their
 * `recommendedThemes`. Used purely as a soft hint (★ badge on matching
 * swatches when the corresponding design is active). Pre-computed at
 * build time so the modal stays zero-JS for the initial paint.
 */
const recommendedBy: Record<string, string[]> = {};
for (const d of DESIGNS) {
  for (const t of d.recommendedThemes ?? []) {
    (recommendedBy[t] ??= []).push(d.id);
  }
}
const recFor = (themeId: string): string => (recommendedBy[themeId] ?? []).join(' ');
---

{position === 'head' && (
<script is:inline define:vars={{ THEME_IDS, DESIGN_IDS, DEFAULT_DESIGN }}>
  const VALID_THEMES = THEME_IDS;
  const VALID_DESIGNS = DESIGN_IDS;

  const __theme = (() => {
    const url = new URL(window.location.href);
    const param = url.searchParams.get('theme');
    if (param && VALID_THEMES.includes(param)) {
      localStorage.setItem('theme', param);
      url.searchParams.delete('theme');
      history.replaceState(null, '', url.pathname + url.search + url.hash);
      return param;
    }
    if (typeof localStorage !== 'undefined') {
      const saved = localStorage.getItem('theme');
      if (saved && VALID_THEMES.includes(saved)) return saved;
    }
    if (window.matchMedia('(prefers-color-scheme: light)').matches) {
      return 'light';
    }
    return 'dark';
  })();
  document.documentElement.setAttribute('data-theme', __theme);

  const __design = (() => {
    const url = new URL(window.location.href);
    const param = url.searchParams.get('design');
    if (param && VALID_DESIGNS.includes(param)) {
      localStorage.setItem('design', param);
      url.searchParams.delete('design');
      history.replaceState(null, '', url.pathname + url.search + url.hash);
      return param;
    }
    if (typeof localStorage !== 'undefined') {
      const saved = localStorage.getItem('design');
      if (saved && VALID_DESIGNS.includes(saved)) return saved;
    }
    return DEFAULT_DESIGN;
  })();
  document.documentElement.setAttribute('data-design', __design);

  window.setTheme = function(id) {
    if (!VALID_THEMES.includes(id)) {
      console.error(
        'Unknown theme "' + id + '". Available themes:\n' +
        VALID_THEMES.map(function(t) { return '  \u2022 ' + t; }).join('\n')
      );
      return;
    }
    document.documentElement.setAttribute('data-theme', id);
    localStorage.setItem('theme', id);
  };

  window.setDesign = function(id) {
    if (!VALID_DESIGNS.includes(id)) {
      console.error(
        'Unknown design "' + id + '". Available designs:\n' +
        VALID_DESIGNS.map(function(d) { return '  \u2022 ' + d; }).join('\n')
      );
      return;
    }
    document.documentElement.setAttribute('data-design', id);
    localStorage.setItem('design', id);
  };
</script>
)}

{position === 'body' && (
<div id="theme-modal" class="theme-modal" aria-hidden="true">
  <div class="theme-modal-backdrop"></div>
  <div class="theme-modal-panel" role="dialog" aria-modal="true" data-i18n-aria-label>
    <div class="theme-modal-header">
      <div class="theme-modal-title-group">
        <span class="theme-modal-title" data-i18n-title></span>
        <kbd class="theme-modal-hint">Ctrl+K</kbd>
      </div>
      <button class="theme-modal-close" aria-label="Close" data-i18n-close-aria>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="theme-modal-group">
      <span class="theme-modal-label" data-i18n-design></span>
      <div class="theme-modal-design-grid">
        {DESIGNS.filter(d => !d.hidden).map(design => (
          <button
            class="theme-modal-design"
            data-kind="design"
            data-design-id={design.id}
            data-preview-style={design.preview.style}
            style={`--td-font: ${design.preview.font}; --td-radius: ${design.preview.radius};`}
          >
            <span class="theme-modal-design-preview" aria-hidden="true">
              <span class="theme-modal-design-sample">Aa</span>
            </span>
            <span class="theme-modal-design-meta">
              <span class="theme-modal-design-name" data-i18n-design-name={design.id}>{design.label}</span>
              <span class="theme-modal-design-blurb" data-i18n-design-blurb={design.id}>{design.blurb}</span>
            </span>
          </button>
        ))}
      </div>
    </div>

    <div class="theme-modal-divider"></div>

    <div class="theme-modal-group">
      <span class="theme-modal-label">
        <span data-i18n-palette></span>
        <span class="theme-modal-rec-legend" aria-hidden="true">
          <span class="theme-modal-rec-legend-star">★</span>
          <span data-i18n-recommended></span>
        </span>
      </span>
      <div class="theme-modal-subgroup">
        <span class="theme-modal-sublabel" data-i18n-dark></span>
        <div class="theme-modal-grid">
          {darkThemes.map(theme => (
            <button class="theme-modal-swatch" data-kind="theme" data-theme-id={theme.id} data-recommended-for={recFor(theme.id)}>
              <span class="theme-modal-color" style={`--tm-bg: ${theme.preview[0]}; --tm-accent: ${theme.preview[1]}`}></span>
              <span class="theme-modal-name">{theme.label.replace('Default ', '')}</span>
              <span class="theme-modal-rec-badge" aria-hidden="true">★</span>
            </button>
          ))}
        </div>
      </div>
      <div class="theme-modal-subgroup">
        <span class="theme-modal-sublabel" data-i18n-light></span>
        <div class="theme-modal-grid">
          {lightThemes.map(theme => (
            <button class="theme-modal-swatch" data-kind="theme" data-theme-id={theme.id} data-recommended-for={recFor(theme.id)}>
              <span class="theme-modal-color" style={`--tm-bg: ${theme.preview[0]}; --tm-accent: ${theme.preview[1]}`}></span>
              <span class="theme-modal-name">{theme.label.replace('Default ', '')}</span>
              <span class="theme-modal-rec-badge" aria-hidden="true">★</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="theme-modal-footer">
      <span data-i18n-footer></span>
    </div>
  </div>
</div>
)}

<style is:global>
  .theme-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99999;
    align-items: center;
    justify-content: center;
  }

  .theme-modal.open {
    display: flex;
  }

  .theme-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: tm-fade-in 150ms ease;
  }

  @keyframes tm-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .theme-modal-panel {
    position: relative;
    min-width: 340px;
    width: min(520px, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    animation: tm-slide-in 150ms ease;
  }

  @keyframes tm-slide-in {
    from { opacity: 0; transform: translateY(-8px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .theme-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .theme-modal-title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .theme-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-muted);
    border: none;
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .theme-modal-close:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .theme-modal-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .theme-modal-hint {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }

  @media (max-width: 640px) {
    .theme-modal-hint {
      display: none;
    }
  }

  .theme-modal-group + .theme-modal-group {
    margin-top: 0.25rem;
  }

  .theme-modal-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .theme-modal-rec-legend {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--text-muted);
    opacity: 0.8;
  }

  .theme-modal-rec-legend-star {
    color: var(--accent-start);
    font-size: 0.7rem;
    line-height: 1;
  }

  .theme-modal-subgroup + .theme-modal-subgroup {
    margin-top: 0.75rem;
  }

  .theme-modal-sublabel {
    display: block;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
    opacity: 0.85;
  }

  .theme-modal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem;
  }

  .theme-modal-design-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .theme-modal-divider {
    height: 1px;
    background: var(--border-color);
    margin: 0.875rem 0;
  }

  .theme-modal-swatch {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .theme-modal-swatch:hover {
    background: var(--bg-card-hover);
    color: var(--text-primary);
  }

  .theme-modal-swatch.active {
    color: var(--text-primary);
    background: var(--bg-card-hover);
  }

  .theme-modal-color {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--tm-bg) 50%, var(--tm-accent) 50%);
    border: 1.5px solid var(--border-color-hover);
  }

  .theme-modal-swatch.active .theme-modal-color {
    border-color: var(--accent-start);
    box-shadow: 0 0 0 2px var(--glow-color);
  }

  .theme-modal-name {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Recommended-palette hint (soft) ───────────────────────
     Star badge + accent ring appear on swatches whose
     `data-recommended-for` includes the current design id.
     The `data-rec='true'` flag is toggled in refreshActive(). */
  .theme-modal-rec-badge {
    margin-left: auto;
    font-size: 0.7rem;
    line-height: 1;
    color: var(--accent-start);
    opacity: 0;
    transform: scale(0.7);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .theme-modal-swatch[data-rec='true'] .theme-modal-rec-badge {
    opacity: 1;
    transform: scale(1);
  }

  .theme-modal-swatch[data-rec='true'] .theme-modal-color {
    border-color: var(--accent-start);
    box-shadow: 0 0 0 1.5px color-mix(in srgb, var(--accent-start) 55%, transparent);
  }

  .theme-modal-swatch[data-rec='true'] .theme-modal-name {
    color: var(--text-primary);
  }

  /* ── Design swatches ────────────────────────────────────── */
  .theme-modal-design {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-secondary);
    text-align: left;
    transition: border-color var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
  }

  .theme-modal-design:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-color-hover);
    color: var(--text-primary);
  }

  .theme-modal-design.active {
    border-color: var(--accent-start);
    box-shadow: 0 0 0 1px var(--glow-color);
    color: var(--text-primary);
  }

  .theme-modal-design-preview {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--td-radius, 0.5rem);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    overflow: hidden;
    position: relative;
  }

  .theme-modal-design-sample {
    font-family: var(--td-font, inherit);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .theme-modal-design[data-preview-style='gradient'] .theme-modal-design-preview {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-secondary) 55%, color-mix(in oklab, var(--accent-start) 35%, var(--bg-secondary)) 100%);
  }
  .theme-modal-design[data-preview-style='gradient'] .theme-modal-design-preview::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
  }

  .theme-modal-design[data-preview-style='serif'] .theme-modal-design-sample {
    font-style: italic;
  }
  .theme-modal-design[data-preview-style='serif'] .theme-modal-design-preview {
    border-radius: 0;
    border-bottom: 2px solid var(--text-primary);
  }

  .theme-modal-design[data-preview-style='blur'] .theme-modal-design-preview {
    background:
      radial-gradient(circle at 30% 30%, color-mix(in oklab, var(--accent-start) 40%, transparent), transparent 60%),
      radial-gradient(circle at 70% 70%, color-mix(in oklab, var(--accent-end) 40%, transparent), transparent 60%),
      var(--bg-secondary);
    border: 1px solid color-mix(in oklab, var(--text-primary) 15%, transparent);
  }

  .theme-modal-design[data-preview-style='grid'] .theme-modal-design-preview {
    border-radius: 0;
    border: 1px solid var(--text-primary);
  }
  .theme-modal-design[data-preview-style='grid'] .theme-modal-design-preview::before {
    content: '02';
    position: absolute;
    top: 2px; right: 4px;
    font-size: 0.55rem;
    font-weight: 800;
    color: #e10600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .theme-modal-design[data-preview-style='soft'] .theme-modal-design-preview {
    background: var(--bg-primary);
    border: 0;
    box-shadow: 2px 2px 6px rgba(0, 0, 0, 0.25), -2px -2px 6px rgba(255, 255, 255, 0.04);
  }

  .theme-modal-design[data-preview-style='pixel'] .theme-modal-design-preview {
    border-radius: 0;
    border: 2px solid var(--text-primary);
    box-shadow: 2px 2px 0 var(--text-primary);
    background: var(--bg-secondary);
  }
  .theme-modal-design[data-preview-style='pixel'] .theme-modal-design-sample {
    font-size: 0.65rem;
  }

  .theme-modal-design[data-preview-style='terminal'] .theme-modal-design-preview {
    border-radius: 0;
    border: 1px dashed var(--accent-start);
    background: var(--bg-secondary);
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.12) 2px,
      rgba(0, 0, 0, 0.12) 3px
    );
  }
  .theme-modal-design[data-preview-style='terminal'] .theme-modal-design-sample {
    font-size: 0.8rem;
    color: var(--accent-start);
  }
  .theme-modal-design[data-preview-style='terminal'] .theme-modal-design-sample::before {
    content: '>';
    margin-right: 2px;
    opacity: 0.7;
  }

  .theme-modal-design[data-preview-style='neon'] .theme-modal-design-preview {
    border-radius: 0;
    border: 1px solid var(--accent-start);
    background:
      linear-gradient(transparent 0, transparent 60%, color-mix(in oklab, var(--accent-start) 35%, transparent) 100%),
      var(--bg-secondary);
    box-shadow: 0 0 10px color-mix(in oklab, var(--accent-start) 40%, transparent),
      inset 0 0 8px color-mix(in oklab, var(--accent-start) 15%, transparent);
  }
  .theme-modal-design[data-preview-style='neon'] .theme-modal-design-sample {
    text-shadow: -1px 0 0 #ff2e88, 1px 0 0 #00f0ff;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .theme-modal-design[data-preview-style='clay'] .theme-modal-design-preview {
    background: var(--bg-secondary);
    border: 0;
    border-radius: 1rem;
    box-shadow:
      0 4px 10px -3px color-mix(in oklab, var(--accent-start) 40%, transparent),
      0 8px 14px -6px rgba(0, 0, 0, 0.2),
      inset 0 -2px 4px -1px rgba(0, 0, 0, 0.18),
      inset 0 2px 4px -1px rgba(255, 255, 255, 0.35);
  }

  .theme-modal-design[data-preview-style='paper'] .theme-modal-design-preview {
    background-color: var(--bg-secondary);
    background-image:
      linear-gradient(to right, color-mix(in oklab, var(--text-primary) 12%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in oklab, var(--text-primary) 12%, transparent) 1px, transparent 1px);
    background-size: 8px 8px;
    border: 1px solid color-mix(in oklab, var(--text-primary) 35%, transparent);
    border-radius: 0.4rem;
    transform: rotate(-2deg);
    box-shadow: 2px 3px 0 color-mix(in oklab, var(--text-primary) 20%, transparent);
  }
  .theme-modal-design[data-preview-style='paper'] .theme-modal-design-sample {
    transform: rotate(2deg);
    position: relative;
  }
  .theme-modal-design[data-preview-style='paper'] .theme-modal-design-sample::after {
    content: '';
    position: absolute;
    left: -2px;
    right: -2px;
    bottom: 2px;
    height: 5px;
    background: color-mix(in oklab, var(--accent-start) 40%, #fff58a);
    opacity: 0.6;
    z-index: -1;
    border-radius: 1px;
  }

  .theme-modal-design[data-preview-style='raw'] .theme-modal-design-preview {
    background: #ffe000;
    border: 3px solid var(--text-primary);
    border-radius: 0;
    box-shadow: 3px 3px 0 var(--text-primary);
  }
  .theme-modal-design[data-preview-style='raw'] .theme-modal-design-sample {
    font-weight: 900;
    font-style: italic;
    color: #000;
  }

  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-preview {
    background-color: color-mix(in oklab, var(--bg-secondary) 82%, var(--accent-start));
    background-image:
      linear-gradient(to right, color-mix(in oklab, var(--accent-start) 45%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in oklab, var(--accent-start) 45%, transparent) 1px, transparent 1px);
    background-size: 6px 6px;
    border: 1px solid var(--accent-start);
    border-radius: 0;
    position: relative;
  }
  /* Corner tick marks on the tile preview */
  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-preview::before,
  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-preview::after {
    content: '';
    position: absolute;
    width: 6px;
    height: 6px;
    border: 2px solid var(--accent-start);
    z-index: 1;
  }
  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-preview::before {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }
  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-preview::after {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }
  .theme-modal-design[data-preview-style='schematic'] .theme-modal-design-sample {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .theme-modal-design[data-preview-style='tex'] .theme-modal-design-preview {
    background: color-mix(in oklab, #f4ecd8 30%, var(--bg-secondary));
    border-radius: 0;
    border-top: 1px solid var(--text-primary);
    border-bottom: 1px solid var(--text-primary);
    border-left: 0;
    border-right: 0;
  }
  .theme-modal-design[data-preview-style='tex'] .theme-modal-design-preview::before {
    content: '§ 1';
    position: absolute;
    top: 3px;
    left: 3px;
    font-size: 0.5rem;
    letter-spacing: 0;
    color: var(--accent-start);
    font-family: 'EB Garamond', 'Crimson Pro', serif;
    font-style: italic;
  }
  .theme-modal-design[data-preview-style='tex'] .theme-modal-design-sample {
    font-style: italic;
    font-weight: 400;
  }

  .theme-modal-design[data-preview-style='editor'] .theme-modal-design-preview {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color-hover);
    border-radius: 0.2rem;
    overflow: hidden;
  }
  .theme-modal-design[data-preview-style='editor'] .theme-modal-design-preview::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 7px;
    background: color-mix(in oklab, var(--bg-primary) 60%, transparent);
    border-bottom: 1px solid var(--border-color);
