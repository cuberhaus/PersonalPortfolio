---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<button
  id="scroll-to-top"
  class="scroll-to-top"
  aria-label={t('aria.scrollTop')}
  title={t('aria.scrollTop')}
  tabindex="-1"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M12 19V5M5 12l7-7 7 7" />
  </svg>
</button>

<style>
  .scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--accent-gradient);
    color: white;
    box-shadow: 0 4px 14px var(--glow-color-strong);
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
    transition: opacity var(--transition-base), transform var(--transition-base), box-shadow var(--transition-base);
  }

  .scroll-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .scroll-to-top:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px var(--glow-color-strong);
  }

  .scroll-to-top:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .scroll-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>

<script>
  let scrollTopHandler: (() => void) | undefined;

  document.addEventListener('astro:page-load', () => {
    const scrollBtn = document.getElementById('scroll-to-top');
    if (!scrollBtn) return;

    if (scrollTopHandler) {
      window.removeEventListener('scroll', scrollTopHandler);
    }

    scrollTopHandler = () => {
      if (window.scrollY > 300) {
        scrollBtn.classList.add('visible');
        scrollBtn.removeAttribute('tabindex');
      } else {
        scrollBtn.classList.remove('visible');
        scrollBtn.setAttribute('tabindex', '-1');
      }
    };

    window.addEventListener('scroll', scrollTopHandler, { passive: true });
    scrollTopHandler();

    if (!scrollBtn.hasAttribute('data-initialized')) {
      scrollBtn.setAttribute('data-initialized', 'true');
      scrollBtn.addEventListener('click', () => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.__debug?.log?.('info', 'ui:scroll', 'to-top');
        window.scrollTo({
          top: 0,
          behavior: prefersReduced ? 'auto' : 'smooth'
        });
      });
    }
  });
</script>