---
interface Props {
  badge: string;
  title: string;
  lead: string;
  githubUrl: string | string[];
  githubLabel: string | string[];
  accentFrom?: string;
  accentTo?: string;
}

const {
  badge,
  title,
  lead,
  githubUrl,
  githubLabel,
  accentFrom = 'var(--accent-start)',
  accentTo = 'var(--accent-end)',
} = Astro.props;

const urls = Array.isArray(githubUrl) ? githubUrl : [githubUrl];
const labels = Array.isArray(githubLabel) ? githubLabel : [githubLabel];
---

<div class="demo-header" style={`--hdr-from: ${accentFrom}; --hdr-to: ${accentTo};`}>
  <div class="demo-hdr-badge">{badge}</div>
  <h1 class="demo-hdr-title">{title}</h1>
  <p class="demo-hdr-lead" set:html={lead} />
  <slot />
  <div class="demo-header-actions">
    {urls.map((url, i) => (
      <a href={url} class="demo-header-github" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
        {labels[i] ?? labels[0]}
      </a>
    ))}
  </div>
</div>

<style>
  .demo-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .demo-hdr-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--hdr-from) 15%, transparent),
      color-mix(in srgb, var(--hdr-to) 10%, transparent));
    border: 1px solid color-mix(in srgb, var(--hdr-from) 25%, transparent);
    color: var(--hdr-from);
    margin-bottom: 1rem;
  }

  .demo-hdr-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.85rem;
    background: linear-gradient(135deg, var(--hdr-from), var(--hdr-to));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .demo-hdr-lead {
    color: var(--text-secondary);
    max-width: 40rem;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }

  .demo-hdr-lead :global(strong) {
    color: var(--text-primary, #e4e4e7);
  }
</style>
