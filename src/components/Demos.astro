---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { renderIconSvg } from '../lib/demo-icons';
import demosEn from '../data/demos.json';
import demosEs from '../data/demos.es.json';
import demosCa from '../data/demos.ca.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const demos = lang === 'es' ? demosEs : lang === 'ca' ? demosCa : demosEn;

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section class="section demos" id="projects">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('projects.label')}</span>
      <h2 class="section-title">{t('projects.title')}</h2>
      <p class="section-subtitle">
        {t('projects.subtitle')}
      </p>
    </div>

    <div class="demo-grid reveal-stagger" id="demo-grid">
      {demos.map((demo, index) => (
        <article class={`demo-card ${index >= 6 ? 'hidden-demo extra-demo' : ''}${index >= 3 && index < 6 ? ' mobile-extra-demo mobile-hidden-demo' : ''}`} data-index={index}>
          <div class="demo-card-inner">
            <div class="demo-icon" set:html={renderIconSvg(demo.icon, 28)} />

            {/* GitHub link moved to footer */}

            <div class="demo-badge">
              <span>{t('projects.badge')}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>

            <h3 class="demo-title">
              <a href={`${base}${lang === 'en' ? '' : `/${lang}`}/demos/${demo.slug}/`} class="full-card-link" data-astro-reload>{demo.title}</a>
            </h3>
            <p class="demo-desc">{demo.description}</p>

          <div class="demo-card-footer">
            <ul class="demo-tags">
              {demo.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>

            {demo.github && (
              <div style="display: flex; gap: 0.5rem;">
                {(Array.isArray(demo.github) ? demo.github : [demo.github]).map((link) => (
                  <a href={link} class="demo-github-link" target="_blank" rel="noopener noreferrer" aria-label={t('aria.viewGithub')}>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                      <path d="M9 18c-4.51 2-5-2-7-2"/>
                    </svg>
                  </a>
                ))}
              </div>
            )}
          </div>
          </div>
        </article>
      ))}
    </div>

    {demos.length > 6 && (
      <div class="show-more-container reveal">
        <button id="show-more-demos" class="show-more-btn" aria-expanded="false" aria-controls="demo-grid" data-more={t('projects.showMore')} data-less={t('projects.showLess')}>
          {t('projects.showMore')}
        </button>
      </div>
    )}
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('show-more-demos');
    if (!btn || btn.hasAttribute('data-initialized')) return;
    btn.setAttribute('data-initialized', 'true');

    const isMobile = () => window.matchMedia('(max-width: 640px)').matches;
    const getCards = () => [...document.querySelectorAll('#demo-grid .demo-card[data-index]')];
    const totalCount = getCards().length;
    let mobileShown = 3;

    function scrollToProjects() {
      const section = document.getElementById('projects');
      if (section) {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        section.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth' });
      }
    }

    btn.addEventListener('click', () => {
      if (isMobile()) {
        if (mobileShown >= totalCount) {
          // Collapse back to 3
          getCards().forEach(card => {
            const idx = parseInt(card.getAttribute('data-index') || '0');
            if (idx >= 3) {
              card.classList.remove('visible');
              setTimeout(() => {
                if (idx >= 6) card.classList.add('hidden-demo');
                else card.classList.add('mobile-hidden-demo');
              }, 400);
            }
          });
          mobileShown = 3;
          btn.textContent = btn.getAttribute('data-more');
          btn.setAttribute('aria-expanded', 'false');
          btn.classList.remove('expanded');
          scrollToProjects();
        } else {
          // Reveal next 3
          const end = Math.min(mobileShown + 3, totalCount);
          let stagger = 0;
          for (let i = mobileShown; i < end; i++) {
            const card = getCards().find(c => c.getAttribute('data-index') === String(i));
            if (card) {
              card.classList.remove('hidden-demo', 'mobile-hidden-demo');
              const delay = 20 + stagger * 60;
              setTimeout(() => card.classList.add('visible'), delay);
              stagger++;
            }
          }
          mobileShown = end;
          if (mobileShown >= totalCount) {
            btn.textContent = btn.getAttribute('data-less');
            btn.setAttribute('aria-expanded', 'true');
            btn.classList.add('expanded');
          }
        }
      } else {
        // Desktop: toggle all extras at once
        const isExpanded = btn.classList.toggle('expanded');
        btn.setAttribute('aria-expanded', String(isExpanded));

        getCards().forEach(card => {
          const idx = parseInt(card.getAttribute('data-index') || '0');
          if (idx < 6) return;
          if (isExpanded) {
            card.classList.remove('hidden-demo');
            setTimeout(() => card.classList.add('visible'), 20 + ((idx - 6) * 60));
          } else {
            card.classList.remove('visible');
            setTimeout(() => card.classList.add('hidden-demo'), 400);
          }
        });

        btn.textContent = isExpanded
          ? btn.getAttribute('data-less')
          : btn.getAttribute('data-more');

        if (!isExpanded) scrollToProjects();
      }
    });
  });
</script>

<style>
  .demo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .demo-card {
    position: relative;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    transition: transform var(--transition-base), border-color var(--transition-base),
                box-shadow var(--transition-base);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .demo-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .demo-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-start);
    box-shadow: 0 12px 40px var(--glow-color);
  }

  .demo-card:hover::before {
    opacity: 1;
  }

  .demo-card-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .demo-icon {
    color: var(--accent-start);
    margin-bottom: 1.25rem;
  }

  .demo-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-start);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity var(--transition-base), transform var(--transition-base);
    pointer-events: none;
    z-index: 5;
  }

  .demo-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: auto;
    gap: 1rem;
  }

  .demo-github-link {
    position: relative;
    z-index: 10;
    color: var(--text-muted);
    transition: color var(--transition-fast), transform var(--transition-fast);
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .demo-github-link:hover {
    color: var(--text-primary);
    transform: scale(1.1);
  }

  .full-card-link {
    color: inherit;
    text-decoration: none;
  }

  .full-card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .demo-card:hover .demo-badge {
    opacity: 1;
    transform: translateX(0);
    pointer-events: none; /* Make sure the badge doesn't block the github link clicks if it somehow overlaps */
  }

  .demo-title {
    font-size: 1.15rem;
    margin-bottom: 0.65rem;
    transition: color var(--transition-fast);
  }

  .demo-card:hover .demo-title {
    color: var(--accent-start);
  }

  .demo-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .demo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .demo-tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 1024px) {
    .demo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .demo-grid {
      grid-template-columns: 1fr;
    }

    .mobile-hidden-demo {
      display: none !important;
    }

    .mobile-extra-demo {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
      transition-delay: 0ms !important;
    }

    .mobile-extra-demo.visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hidden-demo {
    display: none !important;
  }

  .extra-demo {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
    transition-delay: 0ms !important;
  }

  .extra-demo.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .show-more-container {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  .show-more-btn {
    background: transparent;
    border: 1px solid var(--accent-start);
    color: var(--accent-start);
    padding: 0.75rem 2rem;
    border-radius: 2rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }

  .show-more-btn:hover {
    background: rgba(88, 166, 255, 0.1);
    box-shadow: 0 0 15px rgba(88, 166, 255, 0.2);
    transform: translateY(-2px);
  }

  .show-more-btn:active {
    transform: translateY(0);
  }
</style>
