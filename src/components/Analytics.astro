---
// Google Analytics (GA4) — set PUBLIC_GA_ID in your environment to activate.
// In production GitHub Pages deploys, set it as a repo variable / secret and
// expose it to the build step (Astro inlines PUBLIC_*-prefixed env vars).
const measurementId = (import.meta.env.PUBLIC_GA_ID ?? '').trim();
const isValid = /^G-[A-Z0-9]+$/.test(measurementId);
---

{isValid && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`} is:inline></script>
    <script define:vars={{ measurementId }} is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', measurementId);
    </script>
  </>
)}
