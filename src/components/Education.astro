---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { education as educationData, getTranslations } from '../data/loaders';
import { visibleEntries } from '../data/visibility';
import { flattenForLocale } from '../i18n/load';

type EduEntry = {
  degree: string;
  institution: string;
  location: string;
  period: string;
  link: string;
  hidden?: boolean;
};

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const education = visibleEntries(
  flattenForLocale<EduEntry>(educationData as never, lang, getTranslations('education', lang))
);

const { num } = Astro.props;
---

<section class="section education" id="education" data-num={num}>
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('education.label')}</span>
      <h2 class="section-title">{t('education.title')}</h2>
    </div>

    <ul class="education-grid reveal-stagger">
      {
        education.map((entry) => (
          <li class="education-card">
            <a href={entry.link} target="_blank" rel="noopener noreferrer" class="education-link">
              <div class="education-icon" aria-hidden="true">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                  <path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5" />
                </svg>
              </div>
              <span class="education-period">{entry.period}</span>
              <h3 class="education-degree">{entry.degree}</h3>
              <p class="education-institution">{entry.institution}</p>
              <p class="education-location">{entry.location}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .education-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .education-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .education-card:hover {
    border-color: var(--accent-text);
    box-shadow: 0 12px 40px var(--glow-color);
  }

  .education-card:hover::before {
    opacity: 1;
  }

  .education-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .education-icon {
    color: var(--accent-text);
    margin-bottom: 1.25rem;
  }

  .education-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-text);
    display: block;
    margin-bottom: 0.5rem;
  }

  .education-degree {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .education-institution {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .education-location {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .education-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
