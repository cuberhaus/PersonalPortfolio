---
import { ViewTransitions } from 'astro:transitions';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ScrollToTop from '../components/ScrollToTop.astro';
import ThemeInit from '../components/ThemeInit.astro';
import DebugInit from '../components/DebugInit.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pol Casacuberta — Portfolio',
  description = 'Computer Science Engineer specializing in AI, data science, and machine learning.',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <ThemeInit position="head" />
    <DebugInit />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(base + "/og-image.jpg", Astro.site || Astro.url)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(base + "/og-image.jpg", Astro.site || Astro.url)} />

    <link rel="canonical" href={Astro.url} />
    <link rel="alternate" hreflang="en" href={new URL(base + '/', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="es" href={new URL(base + '/es/', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="ca" href={new URL(base + '/ca/', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="x-default" href={new URL(base + '/', Astro.site || Astro.url)} />
    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Inter+Tight:wght@500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Inter+Tight:wght@500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&family=Playfair+Display:ital,wght@0,700;0,800;1,800;1,900&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=Press+Start+2P&family=Orbitron:wght@500;700;900&family=Caveat:wght@500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Poiret+One&family=Shippori+Mincho:wght@400;500;600;700&family=Bangers&family=UnifrakturMaguntia&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Pol Casacuberta",
      "url": Astro.site?.toString() || Astro.url.origin,
      "jobTitle": "AI & Data Consultant",
      "sameAs": [
        "https://github.com/cuberhaus",
        "https://linkedin.com/in/polcasacubertagil"
      ]
    })} />
    <ViewTransitions />
    <Analytics />
  </head>
  <body>
    <ThemeInit position="body" />
    <a href="#main-content" class="skip-to-content">{t('aria.skipToContent')}</a>
    <slot />
    <div class="main-bottom-design">
      <button class="main-design-btn" aria-label={t('theme.customize')} title={t('theme.customize')}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/>
          <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/>
          <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/>
          <circle cx="6.5" cy="12" r=".5" fill="currentColor"/>
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
        </svg>
        <span>{t('theme.customize')}</span>
      </button>
    </div>
    <ScrollToTop />
    <style>
      .main-bottom-design {
        display: none;
        justify-content: center;
        padding: 2rem 0 1rem;
      }
      @media (max-width: 768px) {
        .main-bottom-design {
          display: flex;
        }
      }
      .main-design-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border-radius: var(--radius-full, 9999px);
        background: var(--bg-secondary);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: color var(--transition-fast), background-color var(--transition-fast), border-color var(--transition-fast);
      }
      .main-design-btn:hover {
        color: var(--accent-start);
        background: var(--bg-card);
        border-color: var(--accent-start);
      }
    </style>
    <script>
      function initMainDesignBtn() {
        document.querySelectorAll('.main-design-btn').forEach(btn => {
          if (btn.hasAttribute('data-init')) return;
          btn.setAttribute('data-init', '');
          btn.addEventListener('click', () => {
            document.dispatchEvent(new CustomEvent('open-theme-modal'));
          });
        });
      }
      initMainDesignBtn();
      document.addEventListener('astro:page-load', initMainDesignBtn);
    </script>

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/themes.css';
  @import '../styles/designs.css';
</style>
