---
import { ViewTransitions } from 'astro:transitions';
import { getLangFromUrl } from '../i18n/utils';
import ScrollToTop from '../components/ScrollToTop.astro';
import ThemeInit from '../components/ThemeInit.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pol Casacuberta — Portfolio',
  description = 'Computer Science Engineer specializing in AI, data science, and machine learning.',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <ThemeInit />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(base + "/og-image.jpg", Astro.site || Astro.url)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(base + "/og-image.jpg", Astro.site || Astro.url)} />

    <link rel="canonical" href={Astro.url} />
    <link rel="alternate" hreflang="en" href={new URL(base + '/', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="es" href={new URL(base + '/es', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="ca" href={new URL(base + '/ca', Astro.site || Astro.url)} />
    <link rel="alternate" hreflang="x-default" href={new URL(base + '/', Astro.site || Astro.url)} />
    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Pol Casacuberta",
      "url": Astro.site?.toString() || Astro.url.origin,
      "jobTitle": "AI & Data Consultant",
      "sameAs": [
        "https://github.com/cuberhaus",
        "https://linkedin.com/in/polcasacubertagil"
      ]
    })} />
    <ViewTransitions />
    <Analytics />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <slot />
    <ScrollToTop />

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/themes.css';
</style>
