---
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import DemoNav from '../components/DemoNav.astro';
import DemoSidebar from '../components/DemoSidebar.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ThemeInit from '../components/ThemeInit.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  slug?: string;
}

const { title, description, ogImage, slug } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const demoPath = slug ? `/demos/${slug}/` : Astro.url.pathname;
const siteBase = Astro.site || Astro.url;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title + " — Pol Casacuberta"} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage || (base + "/og-image.jpg"), Astro.site || Astro.url)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title + " — Pol Casacuberta"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage || (base + "/og-image.jpg"), Astro.site || Astro.url)} />

    <link rel="canonical" href={Astro.url} />
    <link rel="alternate" hreflang="en" href={new URL(base + demoPath, siteBase)} />
    <link rel="alternate" hreflang="es" href={new URL(base + '/es' + demoPath, siteBase)} />
    <link rel="alternate" hreflang="ca" href={new URL(base + '/ca' + demoPath, siteBase)} />
    <link rel="alternate" hreflang="x-default" href={new URL(base + demoPath, siteBase)} />

    <ThemeInit position="head" />


    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Inter+Tight:wght@500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&family=Playfair+Display:ital,wght@0,700;0,800;1,800;1,900&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=Press+Start+2P&family=Orbitron:wght@500;700;900&family=Caveat:wght@500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Inter+Tight:wght@500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&family=Playfair+Display:ital,wght@0,700;0,800;1,800;1,900&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=Press+Start+2P&family=Orbitron:wght@500;700;900&family=Caveat:wght@500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title} — Pol Casacuberta</title>
    <Analytics />
  </head>
  <body>
    <ThemeInit position="body" />
    <a href="#main-content" class="skip-to-content">{t('aria.skipToContent')}</a>
    <DemoSidebar currentSlug={slug} />
    <nav class="demo-nav">
      <div class="demo-nav-inner container">
        <a href={base + (lang === 'en' ? '/' : `/${lang}`)} class="demo-back" data-astro-reload>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {t('demo.portfolio')}
        </a>
        <span class="demo-nav-title gradient-text">{title}</span>

        <div class="demo-controls">
          <button class="sidebar-toggle" id="sidebar-toggle" aria-label={t('demo.allDemos')} title={t('demo.allDemos')}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
          <LanguagePicker />
          <ThemeToggle />
        </div>
      </div>
    </nav>

    <main class="demo-main" id="main-content">
      <slot />
      {slug && <DemoNav currentSlug={slug} />}
    </main>


    <style>
      @media (max-width: 768px) {
        .demo-controls :global(.language-picker) {
          margin: 0;
          width: fit-content;
        }
      }
    </style>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/themes.css';
  @import '../styles/designs.css';

  .demo-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--bg-nav);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-color);
  }

  .demo-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: var(--nav-height);
  }

  .sidebar-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .sidebar-toggle:hover {
    color: var(--text-primary);
    background-color: var(--bg-secondary);
  }

  .demo-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
    justify-self: start;
  }

  .demo-back:hover {
    color: var(--text-primary);
  }

  .demo-nav-title {
    font-size: 1rem;
    font-weight: 700;
    justify-self: center;
  }

  .demo-controls {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .demo-main {
    min-height: calc(100vh - var(--nav-height));
    padding: 2rem 0;
    color: var(--text-primary);
  }

  .demo-main p, .demo-main span:not(.demo-nav-title) {
    color: var(--text-primary);
  }

  .demo-main .stats-grid p, .demo-main .stats-grid span {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .demo-nav-inner {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      height: auto;
      padding: 0.75rem 1rem;
      gap: 0.5rem;
    }

    .demo-back {
      order: 1;
    }

    .demo-controls {
      order: 2;
      width: auto;
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
      justify-content: flex-end;
      align-items: center;
    }

    .demo-nav-title {
      order: 3;
      width: 100%;
      text-align: center;
      font-size: 1rem;
      line-height: 1.3;
      margin: 0.25rem 0;
    }
  }
</style>
