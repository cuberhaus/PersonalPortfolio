---
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import DemoNav from '../components/DemoNav.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ThemeInit from '../components/ThemeInit.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  slug?: string;
}

const { title, description, ogImage, slug } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const demoPath = slug ? `/demos/${slug}/` : Astro.url.pathname;
const siteBase = Astro.site || Astro.url;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title + " — Pol Casacuberta"} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage || (base + "/og-image.jpg"), Astro.site || Astro.url)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title + " — Pol Casacuberta"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage || (base + "/og-image.jpg"), Astro.site || Astro.url)} />

    <link rel="canonical" href={Astro.url} />
    <link rel="alternate" hreflang="en" href={new URL(base + demoPath, siteBase)} />
    <link rel="alternate" hreflang="es" href={new URL(base + '/es' + demoPath, siteBase)} />
    <link rel="alternate" hreflang="ca" href={new URL(base + '/ca' + demoPath, siteBase)} />
    <link rel="alternate" hreflang="x-default" href={new URL(base + demoPath, siteBase)} />

    <ThemeInit />


    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>
    
    <title>{title} — Pol Casacuberta</title>
    <Analytics />
  </head>
  <body>
    <nav class="demo-nav">
      <div class="demo-nav-inner container">
        <a href={base + (lang === 'en' ? '/' : `/${lang}`)} class="demo-back" data-astro-reload>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {t('demo.portfolio')}
        </a>
        <span class="demo-nav-title gradient-text">{title}</span>
        
        <div class="demo-controls">
          <LanguagePicker />
          <ThemeToggle />
          <button class="demo-copy-btn" id="copy-demo-link" aria-label={t('demo.copyLink')} title={t('demo.copyLink')} data-copied-text={t('demo.copied')}>
            <svg class="icon-copy" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <svg class="icon-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none; color: var(--accent-start);">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="demo-main" id="main-content">
      <slot />
      {slug && <DemoNav currentSlug={slug} />}
    </main>

    <script>
      const initCopyBtn = () => {
        const copyBtn = document.getElementById('copy-demo-link');
        if (copyBtn && !copyBtn.hasAttribute('data-initialized')) {
          copyBtn.setAttribute('data-initialized', 'true');
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(window.location.href);
              const iconCopy = copyBtn.querySelector('.icon-copy');
              const iconCheck = copyBtn.querySelector('.icon-check');
              
              if (iconCopy && iconCheck) {
                iconCopy.style.display = 'none';
                iconCheck.style.display = 'block';
                const originalTitle = copyBtn.getAttribute('title');
                const copiedText = copyBtn.getAttribute('data-copied-text') || 'Copied!';
                copyBtn.setAttribute('title', copiedText);
                
                setTimeout(() => {
                  iconCopy.style.display = 'block';
                  iconCheck.style.display = 'none';
                  copyBtn.setAttribute('title', originalTitle || 'Copy link');
                }, 2000);
              }
            } catch {
              // Clipboard API not available
            }
          });
        }
      };

      initCopyBtn();
      document.addEventListener('astro:page-load', initCopyBtn);
    </script>
    <style>
      @media (max-width: 768px) {
        .demo-nav-inner {
          display: flex;
          flex-wrap: wrap;
          justify-content: space-between;
          align-items: center;
          gap: 0.5rem;
          padding: 0.5rem 1rem;
        }
        
        /* Keep "Back to Portfolio" on the top left */
        .demo-back {
          order: 1;
        }
        
        /* Put Theme Toggle and Copy Link side-by-side on the top right */
        .demo-controls {
          order: 2;
          width: auto;
          margin-top: 0;
          display: flex;
          flex-wrap: wrap;
          gap: 0.25rem;
          justify-content: flex-end;
          align-items: center;
        }
        
        /* Make the Title take up the full width below the top row */
        .demo-nav-title {
          order: 3;
          width: 100%;
          text-align: center;
          font-size: 1rem;
          margin: 0.25rem 0;
          line-height: 1.3;
        }
        
        /* Language Picker drops to a third row or sits below */
        .demo-controls .language-picker {
          order: 4;
          width: 100%;
          justify-content: center;
          border-top: none;
          padding-top: 0.25rem;
          margin-top: 0.25rem;
          border-bottom: 1px solid var(--border-color);
          padding-bottom: 0.5rem;
          border-left: none;
          padding-left: 0;
        }
      }
    </style>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/themes.css';

  .demo-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--bg-nav);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-color);
  }

  .demo-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: var(--nav-height);
  }

  .demo-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
    justify-self: start;
  }

  .demo-back:hover {
    color: var(--text-primary);
  }

  .demo-nav-title {
    font-size: 1rem;
    font-weight: 700;
    justify-self: center;
  }

  .demo-controls {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .demo-copy-btn {
    justify-self: end;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .demo-copy-btn:hover {
    color: var(--text-primary);
    background-color: var(--bg-secondary);
  }

  .demo-main {
    min-height: calc(100vh - var(--nav-height));
    padding: 2rem 0;
    color: var(--text-primary);
  }

  .demo-main p, .demo-main span:not(.demo-nav-title) {
    color: var(--text-primary);
  }

  .demo-main .stats-grid p, .demo-main .stats-grid span {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .demo-nav-inner {
      display: flex;
      flex-direction: column;
      height: auto;
      padding: 1rem 1.5rem;
      gap: 1rem;
    }

    .demo-back {
      align-self: flex-start;
      margin-bottom: 0.5rem;
    }

    .demo-nav-title {
      text-align: center;
      font-size: 1.1rem;
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }

    .demo-controls {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
