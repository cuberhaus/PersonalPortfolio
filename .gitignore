node_modules/
dist/
.astro/
verification-screenshots/
coverage/

.build-stamps/

.env
.env.*
.DS_Store

# CV PDFs fetched from cuberhaus/cv releases at build time
public/cv.pdf
public/cv_es.pdf
public/cv_ca.pdf
public/cv/

# OG images regenerated on every deploy by scripts/capture-og-images.mjs
public/og-image.png
public/og/

# Playwright
test-results/
playwright-report/
blob-report/

# planner-api (Python)
planner-api/.venv/
planner-api/**/__pycache__/
planner-api/**/.pytest_cache/

# Translation export/import working files
translations/

# inlang runtime cache
project.inlang/cache/

NUL
# Agent skills installed content (lockfile-tracked, content reproducible via `make skills-restore`)
.agents/skills/

# graphify: keep graph.json / GRAPH_REPORT.md / graph.html / manifest.json /
# .graphify_labels.json + the semantic cache (skips LLM re-extraction on re-run);
# drop the AST cache, stat index, temp files, and machine-local scratch
graphify-out/cache/ast/
graphify-out/cache/stat-index.json
graphify-out/cache/*.tmp
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/cost.json

# understand-anything: keep knowledge-graph / meta / fingerprints + scan-result.json
# (lets the next run skip Phase 1 SCAN); drop the rest of the scratch
.understand-anything/intermediate/*
!.understand-anything/intermediate/scan-result.json
.understand-anything/tmp/
.understand-anything/.trash-*/
